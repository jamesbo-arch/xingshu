.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: rgba(251, 247, 238, 0.92);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  backdrop-filter: blur(20px) saturate(160%);
  display: flex;
  flex-direction: row;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 50;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(126, 102, 64, 0.18);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding-top: 12rpx;
  cursor: pointer;
  transition: color 0.18s;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.tab-text {
  font-size: 20rpx;
  color: #A8A39B;
  line-height: 1.2;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  letter-spacing: 1px;
}

.tab-text.active {
  color: #2A2723;
  font-weight: 600;
}
