.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: #FBF7EE;
  display: flex;
  flex-direction: row;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 50;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(126, 102, 64, 0.14);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding-top: 12rpx;
  cursor: pointer;
}

.tab-icon {
  font-size: 36rpx;
  color: #A8A39B;
  line-height: 1;
  transition: color 0.2s;
}

.tab-icon.active {
  color: #2A2723;
}

.tab-text {
  font-size: 20rpx;
  color: #A8A39B;
  line-height: 1.2;
}

.tab-text.active {
  color: #2A2723;
  font-weight: 600;
}
