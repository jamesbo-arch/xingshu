<view class="tab-bar" hidden="{{hidden}}">
  <view class="tab-bar-border"></view>
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-bar-item"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <text class="tab-icon {{selected === index ? 'active' : ''}}">{{selected === index ? item.activeIcon : item.icon}}</text>
    <text class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</text>
  </view>
</view>
