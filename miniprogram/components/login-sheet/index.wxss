.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #D6D0C2;
  margin: 0 auto 28rpx;
}

.login-sheet {
  padding: 24rpx 48rpx 0;
  text-align: center;
}

.serif {
  font-family: Georgia, "Songti SC", "Noto Serif SC", serif;
}

.login-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 3px;
  margin-bottom: 18rpx;
}

.login-subtitle {
  display: block;
  font-size: 26rpx;
  color: #7A746A;
  line-height: 1.8;
  margin-bottom: 36rpx;
  padding: 0 8rpx;
}

/* 协议勾选 */
.agree-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
  padding: 8rpx 0;
}

.agree-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1px solid #D6D0C2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.agree-check.checked {
  background: #8B7A4A;
  border-color: #8B7A4A;
}

.agree-tick {
  font-size: 20rpx;
  color: #FFFCF5;
  line-height: 1;
}

.agree-text {
  font-size: 24rpx;
  color: #7A746A;
}

.agree-link {
  color: #8B7A4A;
}

/* 微信登录按钮（文字在图标上方） */
.login-btn-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.login-btn-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2723;
  letter-spacing: 2px;
}

.wx-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #07C160;
  position: relative;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.28);
  transition: opacity 0.2s ease;
}

.wx-icon-dim {
  opacity: 0.45;
  box-shadow: none;
}

.wx-bubble {
  position: absolute;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.wx-bubble-main {
  width: 54rpx;
  height: 42rpx;
  border-radius: 22rpx 22rpx 6rpx 22rpx;
  top: 26rpx;
  left: 20rpx;
}

.wx-bubble-sub {
  width: 40rpx;
  height: 32rpx;
  border-radius: 16rpx 16rpx 16rpx 4rpx;
  bottom: 24rpx;
  right: 18rpx;
  gap: 6rpx;
}

.wx-eye {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #07C160;
}

.wx-eye.sm {
  width: 6rpx;
  height: 6rpx;
}

.login-footnote {
  display: block;
  font-size: 22rpx;
  color: #A8A39B;
  margin-bottom: 24rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 24rpx;
}
