.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #D6D0C2;
  margin: 0 auto 28rpx;
}

.login-sheet {
  padding: 24rpx 48rpx 0;
  text-align: center;
}

.serif {
  font-family: Georgia, "Songti SC", "Noto Serif SC", serif;
}

.login-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 3px;
  margin-bottom: 18rpx;
}

.login-subtitle {
  display: block;
  font-size: 26rpx;
  color: #7A746A;
  line-height: 1.8;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

/* 头像 + 昵称 */
.profile-fields {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 132rpx;
  height: 132rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  position: relative;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: #EFE7D4;
  border: 1px solid rgba(126, 102, 64, 0.18);
  box-sizing: border-box;
}

.avatar-cam {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #8B7A4A;
  border: 3rpx solid #FFFCF5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-cam-plus {
  color: #fff;
  font-size: 30rpx;
  line-height: 1;
}

.avatar-hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #A8A39B;
}

.nickname-row {
  margin-top: 20rpx;
  width: 380rpx;
  border-bottom: 1px solid rgba(126, 102, 64, 0.24);
}

.nickname-input {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: #2A2723;
  height: 60rpx;
  line-height: 60rpx;
}

/* 协议勾选 */
.agree-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
  padding: 8rpx 0;
}

.agree-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1px solid #D6D0C2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.agree-check.checked {
  background: #8B7A4A;
  border-color: #8B7A4A;
}

.agree-tick {
  font-size: 20rpx;
  color: #FFFCF5;
  line-height: 1;
}

.agree-text {
  font-size: 24rpx;
  color: #7A746A;
}

.agree-link {
  color: #8B7A4A;
}

/* 登录按钮（实心药丸） */
.login-btn-area {
  margin: 8rpx auto 32rpx;
  width: 64%;
  height: 88rpx;
  border-radius: 999rpx;
  background: #2A2723;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(42, 39, 35, 0.22);
  transition: opacity 0.2s ease;
}

.login-btn-dim {
  opacity: 0.4;
  box-shadow: none;
}

.login-btn-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFCF5;
  letter-spacing: 4rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 24rpx;
}
