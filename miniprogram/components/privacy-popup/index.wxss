.pp-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pp-box {
  width: 600rpx;
  background: #FFFCF5;
  border-radius: 20rpx;
  padding: 44rpx 40rpx 32rpx;
  box-sizing: border-box;
}
.pp-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2A2723;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}
.pp-body {
  font-size: 27rpx;
  color: #4A453E;
  line-height: 1.75;
  margin-bottom: 36rpx;
}
.pp-link { color: #B6452F; }
.pp-btns {
  display: flex;
  gap: 20rpx;
}
.pp-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 29rpx;
  margin: 0;
  padding: 0;
}
.pp-disagree {
  color: #7A746A;
  background: #F0EADD;
}
.pp-agree {
  color: #fff;
  background: #B6452F;
}
.pp-agree::after { border: none; }
