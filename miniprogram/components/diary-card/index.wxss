.diary-card {
  width: 100%;
  background: #FFFCF5;
  border-radius: 12px;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  padding: 20rpx 24rpx 16rpx;
  margin-bottom: 14rpx;
}

.card-member {
  background: linear-gradient(180deg, #FFFBED, #FFFCF5 70%);
  border: 1px solid #B89968;
}

.card-private {
  background: #EFE7D4;
  border: 1px dashed rgba(126, 102, 64, 0.35);
}

/* Header */
.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.member-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F4ECD9, #C9A14A);
  border: 1px solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-badge-text {
  font-size: 12rpx;
  color: #9A7E4F;
  font-weight: 700;
  line-height: 1;
}

.card-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.author-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2A2723;
}

.card-time {
  font-size: 20rpx;
  color: #A8A39B;
}

/* Title */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2723;
  line-height: 1.4;
  margin-bottom: 10rpx;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

/* Content preview */
.card-content {
  font-size: 26rpx;
  color: #4A453E;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 12rpx;
}

/* Tags */
.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

/* Stats row */
.card-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 10rpx;
  border-top: 1px solid rgba(126, 102, 64, 0.08);
}

.stats-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.stats-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 6rpx;
}

.stat-icon {
  font-size: 26rpx;
  color: #A8A39B;
}

.stat-icon.liked {
  color: #C25A4E;
}

.stat-icon.faved {
  color: #C9A14A;
}

.stat-count {
  font-size: 22rpx;
  color: #A8A39B;
}

.stat-count.liked {
  color: #C25A4E;
}

.stat-count.faved {
  color: #C9A14A;
}

/* Action buttons for mine page */
.action-btns {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.action-btn {
  padding: 6rpx 20rpx;
  border-radius: 6px;
  font-size: 24rpx;
}

.edit-btn {
  background: rgba(69, 119, 164, 0.1);
  color: #4577A4;
  border: 1px solid rgba(69, 119, 164, 0.25);
}

.delete-btn {
  background: rgba(182, 69, 47, 0.08);
  color: #B6452F;
  border: 1px solid rgba(182, 69, 47, 0.2);
}
