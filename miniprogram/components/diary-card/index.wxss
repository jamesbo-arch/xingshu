.diary-card {
  width: 100%;
  background: #FFFCF5;
  border-radius: 14px;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  padding: 32rpx 32rpx 20rpx;
  box-shadow: 0 1px 2px rgba(58, 44, 22, 0.04), 0 2px 8px rgba(58, 44, 22, 0.05);
}

.card-member {
  background: linear-gradient(180deg, #FFFBED, #FFFCF5 70%);
  border: 1px solid #B89968;
  box-shadow: 0 1px 3px rgba(184, 153, 104, 0.18), 0 1px 2px rgba(58, 44, 22, 0.04);
}

.card-private {
  background: #EFE7D4;
  border: 1px dashed rgba(126, 102, 64, 0.35);
}

/* Header */
.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.member-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E5C16D, #B89968);
  border: 2px solid #FFFCF5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-badge-text {
  font-size: 16rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.card-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2A2723;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.card-time {
  font-size: 22rpx;
  color: #A8A39B;
}

/* Title */
.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2A2723;
  line-height: 1.45;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  letter-spacing: 1px;
}

/* Content preview */
.card-content {
  font-size: 27rpx;
  color: #4A453E;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* Tags */
.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

/* Divider — extends beyond card padding */
.card-divider {
  height: 1rpx;
  background: rgba(126, 102, 64, 0.14);
  margin: 0 -32rpx 8rpx;
}

/* Stats row */
.card-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 0 -20rpx;
}

.stats-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.stats-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
}

.like-wrap {
  position: relative;
}

.like-float {
  position: absolute;
  top: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  font-weight: 700;
  color: #C25A4E;
  pointer-events: none;
  animation: like-float-up 0.8s ease-out forwards;
}

@keyframes like-float-up {
  0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(-48rpx); }
}

.stat-icon {
  font-size: 36rpx;
  color: #A8A39B;
}

.stat-icon.liked {
  color: #C25A4E;
}

.stat-icon.faved {
  color: #C9A14A;
}

.stat-count {
  font-size: 26rpx;
  color: #A8A39B;
  min-width: 28rpx;
}

.stat-count.liked {
  color: #C25A4E;
}

.stat-count.faved {
  color: #C9A14A;
}

/* Action buttons for mine page */
.action-btns {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 6px;
  font-size: 26rpx;
}

.edit-btn {
  background: rgba(69, 119, 164, 0.1);
  color: #4577A4;
  border: 1px solid rgba(69, 119, 164, 0.25);
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.delete-btn {
  background: rgba(182, 69, 47, 0.08);
  color: #B6452F;
  border: 1px solid rgba(182, 69, 47, 0.2);
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}
