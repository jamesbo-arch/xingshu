<view wx:if="{{_mounted && story}}">
  <view class="sheet-mask {{_show ? 'mask-show' : ''}}" bindtap="onMaskTap"></view>
  <view class="sheet poster-sheet-wrap {{_show ? 'sheet-show' : ''}}" catchtap="onSheetTap">
    <view class="sheet-handle"></view>

    <!-- Paper card（预览：善选副本全文 + 品牌底栏，不展示作者名） -->
    <view class="poster-card">
      <!-- Corner ornaments -->
      <view class="corner corner-tl"></view>
      <view class="corner corner-tr"></view>
      <view class="corner corner-bl"></view>
      <view class="corner corner-br"></view>

      <!-- Header -->
      <view class="poster-header">
        <text class="poster-brand serif">醒書故事</text>
      </view>

      <!-- Title -->
      <view class="poster-title serif">{{shareTitle}}</view>

      <!-- Content：善选副本全文 -->
      <view class="poster-content">{{shareContent}}</view>

      <!-- 配图（副本配图，正文之下） -->
      <view class="poster-images" wx:if="{{shareImages.length}}">
        <image
          wx:for="{{shareImages}}"
          wx:key="*this"
          src="{{item}}"
          mode="widthFix"
          class="poster-img"
        />
      </view>

      <!-- Tags -->
      <view class="poster-tags" wx:if="{{story.tags && story.tags.length}}">
        <text
          wx:for="{{story.tags}}"
          wx:key="*this"
          class="seal-tag"
        >{{item}}</text>
      </view>

      <!-- 品牌底栏：醒书咨询（书本标 + 简介 + 带参小程序码） -->
      <view class="brand-bar">
        <view class="brand-left">
          <view class="brand-book">
            <view class="brand-book-page brand-book-l"></view>
            <view class="brand-book-page brand-book-r"></view>
          </view>
          <text class="brand-name serif">醒书咨询</text>
          <text class="brand-en">XINGSHU CONSULTING</text>
          <text class="brand-slogan serif">以 经 典 导 航</text>
        </view>
        <view class="brand-sep"></view>
        <view class="brand-intro">醒书咨询，一家专注经典文化与现代生活深度对话的机构，为中小企业和个人提供发展咨询服务。</view>
        <view class="brand-qr">
          <image wx:if="{{qrFileID}}" src="{{qrFileID}}" class="brand-qr-img" mode="aspectFit"/>
          <view wx:else class="qr-grid">
            <view wx:for="{{[0,1,2,3,4,5,6,7,8]}}" wx:key="*this" class="qr-dot {{item % 3 === 0 || item % 3 === 2 ? 'qr-dark' : 'qr-light'}}"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Action：仅保存图片（转发走小程序右上角原生菜单） -->
    <view class="poster-actions">
      <view class="btn-primary poster-btn" bindtap="onSaveImage">保存图片</view>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>

<!-- Off-screen canvas for image export（高度随全文动态计算） -->
<canvas type="2d" id="poster-canvas" style="position:fixed;left:-9999px;top:-9999px;width:640px;height:960px;"></canvas>
