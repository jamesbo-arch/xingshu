<view wx:if="{{_mounted && diary}}">
  <view class="sheet-mask {{_show ? 'mask-show' : ''}}" bindtap="onMaskTap"></view>
  <view class="sheet poster-sheet-wrap {{_show ? 'sheet-show' : ''}}" catchtap="onSheetTap">
    <view class="sheet-handle"></view>

    <!-- Paper card -->
    <view class="poster-card">
      <!-- Corner ornaments -->
      <view class="corner corner-tl"></view>
      <view class="corner corner-tr"></view>
      <view class="corner corner-bl"></view>
      <view class="corner corner-br"></view>

      <!-- Header -->
      <view class="poster-header">
        <text class="poster-brand serif">醒書日記</text>
      </view>

      <!-- Title -->
      <view class="poster-title serif">{{diary.title}}</view>

      <!-- Content excerpt -->
      <view class="poster-content">{{contentExcerpt}}</view>

      <!-- Tags -->
      <view class="poster-tags" wx:if="{{diary.tags && diary.tags.length}}">
        <text
          wx:for="{{diary.tags}}"
          wx:key="*this"
          class="seal-tag"
        >{{item}}</text>
      </view>

      <!-- Divider -->
      <view class="poster-divider">
        <view class="divider-line"></view>
        <text class="divider-dot">◆</text>
        <view class="divider-line"></view>
      </view>

      <!-- Author row -->
      <view class="poster-author-row">
        <view class="poster-author-info">
          <view class="avatar sm" style="background-color: {{avatarColor}};">
            <text>{{avatarInitial}}</text>
          </view>
          <view>
            <text class="poster-author-name">{{diary.author}}</text>
            <text class="poster-time">{{diary.dateText}}</text>
          </view>
        </view>
        <!-- v2.2 带参小程序码（scene 携带日记 ID + 分享人 ID，加载失败回退占位） -->
        <view class="qr-placeholder">
          <image wx:if="{{qrFileID}}" src="{{qrFileID}}" class="qr-image" mode="aspectFit"/>
          <view wx:else class="qr-grid">
            <view wx:for="{{[0,1,2,3,4,5,6,7,8]}}" wx:key="*this" class="qr-dot {{item % 3 === 0 || item % 3 === 2 ? 'qr-dark' : 'qr-light'}}"></view>
          </view>
          <text class="qr-label">扫码阅读</text>
        </view>
      </view>
    </view>

    <!-- Action buttons -->
    <view class="poster-actions">
      <view class="btn-ghost poster-btn" bindtap="onSaveImage">保存图片</view>
      <view class="btn-primary poster-btn" bindtap="onShareWechat">分享到微信</view>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>

<!-- Off-screen canvas for image export -->
<canvas type="2d" id="poster-canvas" style="position:fixed;left:-9999px;top:-9999px;width:640px;height:960px;"></canvas>
