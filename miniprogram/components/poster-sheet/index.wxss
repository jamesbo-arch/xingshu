.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.poster-sheet-wrap {
  padding: 24rpx 32rpx 20rpx;
  overflow: hidden;   /* 整体不滚，海报嵌在中间 scroll-view 内滚动 */
}

.poster-sheet-title {
  display: block;
  font-size: 34rpx;
  letter-spacing: 4rpx;
  color: #2A2723;
  margin-bottom: 20rpx;
}

.poster-preview-scroll {
  max-height: 54vh;
  margin-bottom: 20rpx;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #D6D0C2;
  border-radius: 4px;
  margin: 0 auto 24rpx;
}

/* Poster card：原米纸底 + 点阵（沿用原样），页尾出血满宽 */
.poster-card {
  position: relative;
  background: #FFFCF5;
  background-image: radial-gradient(rgba(126, 102, 64, 0.05) 1px, transparent 1px);
  background-size: 18px 18px;
  border-radius: 8px;
  overflow: hidden;
  padding: 28rpx 28rpx 0;
  margin-bottom: 24rpx;
}

/* 花边：矩形边框 + 四角，完整框住故事文字 */
.pc-frame {
  position: relative;
  border: 1px solid rgba(126, 102, 64, 0.2);
  border-radius: 4px;
  padding: 40rpx 32rpx 32rpx;
}

.corner { position: absolute; width: 20rpx; height: 20rpx; }
.corner-tl { top: 8rpx; left: 8rpx; border-top: 1.5px solid rgba(126, 102, 64, 0.4); border-left: 1.5px solid rgba(126, 102, 64, 0.4); }
.corner-tr { top: 8rpx; right: 8rpx; border-top: 1.5px solid rgba(126, 102, 64, 0.4); border-right: 1.5px solid rgba(126, 102, 64, 0.4); }
.corner-bl { bottom: 8rpx; left: 8rpx; border-bottom: 1.5px solid rgba(126, 102, 64, 0.4); border-left: 1.5px solid rgba(126, 102, 64, 0.4); }
.corner-br { bottom: 8rpx; right: 8rpx; border-bottom: 1.5px solid rgba(126, 102, 64, 0.4); border-right: 1.5px solid rgba(126, 102, 64, 0.4); }

/* 页头「醒書故事」标签框（左对齐，活动海报样式） */
.pc-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #B6452F;
  border: 1.5px solid #B6452F;
  border-radius: 6rpx;
  padding: 6rpx 18rpx;
  margin-bottom: 20rpx;
}

/* 故事标题（居中衬线，活动字体色） */
.pc-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #43341F;
  line-height: 1.4;
  text-align: center;
  margin-bottom: 18rpx;
}

/* 正文（左对齐，活动字体色，保留分段） */
.pc-content {
  font-size: 26rpx;
  color: rgba(67, 52, 31, 0.9);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 花边下：配图 */
.pc-images { display: flex; flex-direction: column; gap: 12rpx; margin-top: 24rpx; }
.pc-img { width: 100%; border-radius: 8rpx; display: block; }

/* 二维码 CTA：虚线框 + 文案 + 小程序码 */
.pc-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border: 1.5px dashed #B6452F;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
}

.pc-cta-text { display: flex; flex-direction: column; gap: 10rpx; color: #B6452F; font-size: 24rpx; letter-spacing: 1rpx; }

.pc-qr { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #fff; flex-shrink: 0; }

.pc-qr-loading { display: flex; align-items: center; justify-content: center; font-size: 18rpx; color: rgba(67, 52, 31, 0.5); }

/* Action buttons */
.poster-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.poster-btn {
  flex: 1;
  font-size: 28rpx;
}

/* ── 页尾品牌栏（手绘醒书咨询，出血满宽，与活动邀请函一致）── */
.pc-foot {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #A08A63;
  padding: 22rpx 28rpx;
  margin: 24rpx -28rpx 0;
}

.pcf-logo { flex-shrink: 0; display: flex; flex-direction: column; gap: 4rpx; }
.pcf-name { font-size: 28rpx; font-weight: 700; color: #FDF9F0; letter-spacing: 2rpx; }
.pcf-en { font-size: 14rpx; color: rgba(253, 249, 240, 0.85); letter-spacing: 1rpx; }

.pcf-desc {
  flex: 1;
  font-size: 18rpx;
  line-height: 1.65;
  color: rgba(253, 249, 240, 0.92);
  border-left: 1rpx solid rgba(253, 249, 240, 0.35);
  padding-left: 20rpx;
}
