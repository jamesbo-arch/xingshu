.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.poster-sheet-wrap {
  padding: 24rpx 32rpx 20rpx;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #D6D0C2;
  border-radius: 4px;
  margin: 0 auto 24rpx;
}

/* Poster card（暖色渐变，风格同活动邀请函） */
.poster-card {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: linear-gradient(160deg, #F7EFE0, #EAD9B8);
}

.pc-body { padding: 40rpx 36rpx 32rpx; }

.pc-tag {
  display: inline-block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #B6452F;
  border: 1.5px solid #B6452F;
  border-radius: 6rpx;
  padding: 6rpx 16rpx;
}

.pc-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(67, 52, 31, 0.5);
  margin: 20rpx 0 10rpx;
}

.pc-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #43341F;
  line-height: 1.4;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.pc-content {
  font-size: 25rpx;
  color: rgba(67, 52, 31, 0.9);
  line-height: 1.85;
  white-space: pre-wrap;
  margin-bottom: 20rpx;
}

.pc-images { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.pc-img { width: 100%; border-radius: 8rpx; display: block; }

.pc-divider { height: 1rpx; background: rgba(67, 52, 31, 0.25); margin: 6rpx 0 20rpx; }

.pc-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 22rpx; }

.pc-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border: 1.5px dashed #B6452F;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
}

.pc-cta-text { display: flex; flex-direction: column; gap: 10rpx; color: #B6452F; font-size: 24rpx; letter-spacing: 1rpx; }

.pc-qr { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #fff; flex-shrink: 0; }

.pc-qr-loading { display: flex; align-items: center; justify-content: center; font-size: 18rpx; color: rgba(67, 52, 31, 0.5); }

/* Action buttons */
.poster-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.poster-btn {
  flex: 1;
  font-size: 28rpx;
}

/* ── 页尾品牌栏（手绘醒书咨询，与活动邀请函一致）── */
.pc-foot {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #A08A63;
  padding: 22rpx 36rpx;
}

.pcf-logo { flex-shrink: 0; display: flex; flex-direction: column; gap: 4rpx; }
.pcf-name { font-size: 28rpx; font-weight: 700; color: #FDF9F0; letter-spacing: 2rpx; }
.pcf-en { font-size: 14rpx; color: rgba(253, 249, 240, 0.85); letter-spacing: 1rpx; }

.pcf-desc {
  flex: 1;
  font-size: 18rpx;
  line-height: 1.65;
  color: rgba(253, 249, 240, 0.92);
  border-left: 1rpx solid rgba(253, 249, 240, 0.35);
  padding-left: 20rpx;
}
