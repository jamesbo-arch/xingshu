.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.poster-sheet-wrap {
  padding: 24rpx 32rpx 20rpx;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #D6D0C2;
  border-radius: 4px;
  margin: 0 auto 24rpx;
}

/* Poster card */
.poster-card {
  position: relative;
  background: #FFFCF5;
  background-image: radial-gradient(rgba(126, 102, 64, 0.04) 1px, transparent 1px);
  background-size: 18px 18px;
  border: 1px solid rgba(126, 102, 64, 0.2);
  border-radius: 8px;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
}

/* Corners */
.corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
}

.corner-tl {
  top: 12rpx;
  left: 12rpx;
  border-top: 1.5px solid rgba(126, 102, 64, 0.4);
  border-left: 1.5px solid rgba(126, 102, 64, 0.4);
}

.corner-tr {
  top: 12rpx;
  right: 12rpx;
  border-top: 1.5px solid rgba(126, 102, 64, 0.4);
  border-right: 1.5px solid rgba(126, 102, 64, 0.4);
}

.corner-bl {
  bottom: 12rpx;
  left: 12rpx;
  border-bottom: 1.5px solid rgba(126, 102, 64, 0.4);
  border-left: 1.5px solid rgba(126, 102, 64, 0.4);
}

.corner-br {
  bottom: 12rpx;
  right: 12rpx;
  border-bottom: 1.5px solid rgba(126, 102, 64, 0.4);
  border-right: 1.5px solid rgba(126, 102, 64, 0.4);
}

/* Header */
.poster-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.poster-brand {
  font-size: 28rpx;
  color: #B6452F;
  letter-spacing: 4px;
}

/* Title */
.poster-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A2723;
  line-height: 1.45;
  margin-bottom: 18rpx;
  text-align: center;
}

/* Content：善选副本全文（预览区随 sheet 滚动） */
.poster-content {
  font-size: 26rpx;
  color: #4A453E;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 18rpx;
}

/* Tags */
.poster-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 20rpx;
  justify-content: center;
}

.qr-grid {
  width: 52rpx;
  height: 52rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rpx;
}

.qr-dot {
  border-radius: 1px;
}

.qr-dark {
  background: #2A2723;
}

.qr-light {
  background: #D6D0C2;
}

.qr-label {
  font-size: 18rpx;
  color: #A8A39B;
}

/* Action buttons */
.poster-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.poster-btn {
  flex: 1;
  font-size: 28rpx;
}

/* ── 品牌底栏（醒书咨询样式）── */
.brand-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  background: #B3A188;
  padding: 24rpx 20rpx;
  margin-top: 8rpx;
  clip-path: polygon(20rpx 0, calc(100% - 20rpx) 0, 100% 20rpx, 100% 100%, 0 100%, 0 20rpx);
}

.brand-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex-shrink: 0;
  gap: 2rpx;
}

.brand-book {
  display: flex;
  flex-direction: row;
  gap: 3rpx;
  margin-bottom: 6rpx;
}

.brand-book-page {
  width: 22rpx;
  height: 26rpx;
  background: #1E1A14;
}

.brand-book-l {
  clip-path: polygon(0 0, 100% 25%, 100% 100%, 0 78%);
}

.brand-book-r {
  clip-path: polygon(0 25%, 100% 0, 100% 78%, 0 100%);
}

.brand-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E1A14;
  letter-spacing: 2rpx;
}

.brand-en {
  font-size: 13rpx;
  color: #1E1A14;
  letter-spacing: 1rpx;
}

.brand-slogan {
  font-size: 16rpx;
  color: #1E1A14;
  letter-spacing: 4rpx;
  margin-top: 2rpx;
}

.brand-sep {
  width: 1px;
  align-self: stretch;
  background: rgba(30, 26, 20, 0.5);
  flex-shrink: 0;
}

.brand-intro {
  flex: 1;
  font-size: 19rpx;
  color: #1E1A14;
  line-height: 1.65;
}

.brand-qr {
  flex-shrink: 0;
  background: #FFFCF5;
  border-radius: 8rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-qr-img {
  width: 108rpx;
  height: 108rpx;
}

/* 配图（正文之下逐张全宽展示） */
.poster-images {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.poster-img {
  width: 100%;
  border-radius: 8rpx;
  display: block;
}
