<view
  class="story-card {{story.author_identity !== 'member' ? 'card-gold' : ''}} {{story.publishStatus === 'draft' ? 'card-draft' : ''}}"
  bindtap="onTap"
>
  <!-- Header: avatar + author + time + badge（发布态星号 + 善选眼睛） -->
  <view class="card-header">
    <view class="avatar-wrap">
      <view class="card-avatar" style="background-color: {{avatarColor}};">
        <text class="card-avatar-text">{{avatarInitial}}</text>
      </view>
      <view wx:if="{{story.author_identity === 'member'}}" class="member-badge">
        <text class="member-badge-text">会</text>
      </view>
    </view>
    <view class="card-meta">
      <text class="author-name">{{story.author_name}}</text>
      <text class="card-time">{{story.created_at_text}}</text>
    </view>
    <view wx:if="{{story.publishStatus === 'draft'}}" class="perm-badge perm-private">
      <view class="perm-ic ic-draft"></view>
    </view>
    <block wx:else>
      <!-- 眼睛=已发布；金星=已入选善选 -->
      <view class="perm-badge perm-public">
        <view class="perm-ic ic-eye"></view>
      </view>
      <view wx:if="{{story.isFeatured}}" class="perm-badge perm-member">
        <view class="perm-ic ic-star-gold"></view>
      </view>
    </block>
  </view>

  <!-- Title -->
  <view class="card-title serif">{{story.title}}</view>

  <!-- Content preview -->
  <view class="card-content">{{story.content}}</view>

  <!-- Tags -->
  <view class="card-tags" wx:if="{{story.tags && story.tags.length}}">
    <text
      wx:for="{{story.tags}}"
      wx:key="*this"
      wx:if="{{index < 3}}"
      class="seal-tag"
    >{{item}}</text>
  </view>

  <!-- Divider -->
  <view class="card-divider"></view>

  <!-- Stats row -->
  <view class="card-stats">
    <!-- 作者数据视角（我的故事页）：点击统计项查看人员清单，不触发互动 -->
    <view wx:if="{{ownerStats}}" class="stats-left">
      <view class="stat-item" catch:tap="onViewRead">
        <view class="stat-icon ic-eye"></view>
        <text class="stat-count">{{story.readCount}}</text>
      </view>
      <view class="stat-item" catch:tap="onViewLike">
        <view class="stat-icon ic-heart"></view>
        <text class="stat-count">{{story.likes}}</text>
      </view>
      <view class="stat-item" catch:tap="onViewFav">
        <view class="stat-icon ic-bookmark"></view>
        <text class="stat-count">{{story.favorites}}</text>
      </view>
      <view class="stat-item" catch:tap="onViewComment">
        <view class="stat-icon ic-comment"></view>
        <text class="stat-count">{{story.comments}}</text>
      </view>
    </view>
    <!-- 浏览视角：点赞/收藏可互动；收藏计数按需求不展示数字 -->
    <view wx:else class="stats-left">
      <view class="stat-item like-wrap" catch:tap="onLike">
        <view class="stat-icon {{story.isLiked ? 'ic-heart-on' : 'ic-heart'}}"></view>
        <text class="stat-count {{story.isLiked ? 'liked' : ''}}">{{story.likes}}</text>
        <text wx:if="{{showLikeAnim}}" class="like-float">+1</text>
      </view>
      <view class="stat-item" catch:tap="onFav">
        <view class="stat-icon {{story.isFavorited ? 'ic-bookmark-on' : 'ic-bookmark'}}"></view>
      </view>
      <view class="stat-item">
        <view class="stat-icon ic-comment"></view>
        <text class="stat-count">{{story.comments}}</text>
      </view>
    </view>
    <view class="stats-right">
      <view wx:if="{{showActions}}" class="action-btns">
        <view class="action-btn edit-btn" catch:tap="onEdit">
          <text>编辑</text>
        </view>
        <view class="action-btn delete-btn" catch:tap="onDelete">
          <text>删除</text>
        </view>
      </view>
      <!-- 分享仅善选故事提供（海报面向公众）；非善选只能走右上角原生转发 -->
      <view wx:elif="{{story.isFeatured}}" class="stat-item" catch:tap="onShare">
        <view class="stat-icon ic-share"></view>
        <text class="stat-count">{{story.shares}}</text>
      </view>
    </view>
  </view>
</view>
