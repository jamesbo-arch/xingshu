.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.45);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.sheet-mask.mask-show {
  opacity: 1;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  will-change: transform;
}

.sheet.sheet-show {
  transform: translateY(0);
}

.audience-sheet {
  display: flex;
  flex-direction: column;
  max-height: 70vh;
}

.aud-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #D6D0C2;
  margin: 16rpx auto 8rpx;
  flex-shrink: 0;
}

.aud-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
  padding: 16rpx 40rpx 20rpx;
  border-bottom: 1rpx solid rgba(126, 102, 64, 0.12);
  flex-shrink: 0;
}

.aud-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 1px;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.aud-count {
  font-size: 26rpx;
  color: #A8A39B;
}

.aud-list {
  flex: 1;
  padding: 8rpx 40rpx 0;
}

.aud-empty,
.aud-loading {
  text-align: center;
  color: #A8A39B;
  font-size: 26rpx;
  padding: 48rpx 0;
}

.aud-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(126, 102, 64, 0.08);
}

.aud-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.aud-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.aud-row1 {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.aud-name {
  font-size: 28rpx;
  color: #2A2723;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.aud-time {
  font-size: 22rpx;
  color: #A8A39B;
  flex-shrink: 0;
}

.aud-content {
  font-size: 26rpx;
  color: #4A453E;
  line-height: 1.6;
  word-break: break-all;
}

.aud-bottom-pad {
  height: 40rpx;
}
