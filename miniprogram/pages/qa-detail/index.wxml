<view class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px;"></view>

  <view class="page-header">
    <view class="nav-back" bindtap="onBack"><view class="nav-back-icon ic-back"></view></view>
    <text class="page-title serif">問答</text>
  </view>

  <scroll-view wx:if="{{question}}" class="qa-body" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 问题 -->
    <view class="q-card">
      <view class="q-header">
        <!-- 匿名：默认「醒」字头像，底色按人区分（云函数已脱敏昵称与头像） -->
        <view wx:if="{{question.is_anonymous}}" class="q-avatar" style="background-color: {{question.avatarColor}};"><text>醒</text></view>
        <image wx:elif="{{question.avatar_url}}" class="q-avatar-img" src="{{question.avatar_url}}" mode="aspectFill" />
        <view wx:else class="q-avatar" style="background-color: {{question.avatarColor}};">
          <text>{{question.nickname[0]}}</text>
        </view>
        <view class="q-meta">
          <text class="q-author">{{question.nickname}}</text>
          <text class="q-time">{{question.created_at}}</text>
        </view>
        <view wx:if="{{question.is_featured}}" class="perm-badge perm-member">
          <view class="perm-ic ic-star-gold"></view>
        </view>
      </view>
      <view class="q-content"><text class="q-mark">问：</text>{{question.content}}</view>
    </view>

    <!-- 回复区：公众版可读但不可发 -->
    <view class="replies-section">
      <view class="replies-header">
        <text class="replies-title">回答</text>
        <text class="replies-count ink-3">· {{question.comment_count}}</text>
      </view>

      <view wx:if="{{comments.length === 0}}" class="replies-empty">
        <text class="replies-empty-text">{{canReply ? '还没有回答，来说说你的看法' : '还没有回答'}}</text>
      </view>

      <view wx:for="{{comments}}" wx:key="id" class="reply-item">
        <view wx:if="{{item.is_anonymous}}" class="reply-avatar reply-avatar-anon" style="background-color: {{item.avatarColor}};"><text>醒</text></view>
        <view wx:else class="reply-avatar" style="background-color: {{item.avatarColor}};">
          <text>{{item.nickname[0]}}</text>
        </view>
        <view class="reply-body">
          <view class="reply-header-row">
            <text class="reply-user {{item.isMine ? 'reply-mine' : ''}}">{{item.nickname}}</text>
            <text class="reply-time">{{item.created_at}}</text>
            <text wx:if="{{canReply}}" class="reply-btn" data-id="{{item.id}}" data-user="{{item.nickname}}" bindtap="onReplyTo">回复</text>
            <text wx:if="{{item.isMine}}" class="reply-del" data-id="{{item.id}}" bindtap="onDeleteReply">删除</text>
          </view>
          <text class="reply-content">{{item.content}}</text>

          <!-- 追评（一层） -->
          <view wx:if="{{item.replies.length}}" class="subreplies">
            <view wx:for="{{item.replies}}" wx:key="id" wx:for-item="sub" class="subreply">
              <text class="subreply-user">{{sub.nickname}}</text>
              <text class="subreply-content">{{sub.content}}</text>
              <view class="subreply-foot">
                <text class="subreply-time">{{sub.created_at}}</text>
                <text wx:if="{{sub.isMine}}" class="reply-del" data-id="{{sub.id}}" bindtap="onDeleteReply">删除</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="qa-bottom-pad"></view>
  </scroll-view>

  <!-- 底栏：会员可写回答；公众版只留互动 -->
  <view wx:if="{{question}}" class="bottom-bar">
    <view wx:if="{{canReply}}" class="reply-trigger" bindtap="onShowReplyInput">
      <view class="reply-trigger-icon ic-pen"></view>
      <text class="reply-trigger-text">写回答…</text>
    </view>
    <view wx:else class="reply-trigger-placeholder"></view>
    <view class="bar-actions">
      <view class="bar-action" bindtap="onLike">
        <view class="bar-action-icon {{question.isLiked ? 'ic-heart-on' : 'ic-heart'}}"></view>
      </view>
      <view class="bar-action" bindtap="onFav">
        <view class="bar-action-icon {{question.isFavorited ? 'ic-bookmark-on' : 'ic-bookmark'}}"></view>
      </view>
    </view>
  </view>

  <!-- 写回答浮层 -->
  <view wx:if="{{showReplyInput}}" class="reply-overlay">
    <view class="reply-overlay-mask" bindtap="onHideReplyInput"></view>
    <!-- 回答通常较长：多行 textarea + 独立操作行。
         auto-height 随内容长高，回车即换行，提交只走「发送」按钮 -->
    <view class="reply-input-bar">
      <textarea class="reply-real-input"
        placeholder="{{replyTo ? '回复 ' + replyTo.user : '写下你的回答…'}}"
        placeholder-style="color:#A8A39B;"
        value="{{replyInput}}" bindinput="onReplyInput" focus="{{showReplyInput}}"
        auto-height="{{true}}" maxlength="{{maxReply}}" show-confirm-bar="{{false}}"
        cursor-spacing="20" fixed="{{true}}" />
      <view class="reply-input-actions">
        <text class="reply-counter {{replyInput.length > maxReply - 50 ? 'reply-counter-near' : ''}}">{{replyInput.length}}/{{maxReply}}</text>
        <view class="reply-anon {{replyAnonymous ? 'reply-anon-on' : ''}}" bindtap="onToggleReplyAnonymous">匿名</view>
        <view class="reply-send" bindtap="onSubmitReply">发送</view>
      </view>
    </view>
  </view>

  <login-sheet
    visible="{{showLoginSheet}}"
    subtitle="登录后即可查看并参与醒书问答。"
    bind:close="onLoginClose"
    bind:success="onLoginSuccess"
  ></login-sheet>
</view>

<privacy-popup></privacy-popup>

<!-- 冷启动品牌蒙布（扫码/转发直达本页且当日首次冷启动） -->
<splash-cover visible="{{showSplash}}" bind:enter="onSplashEnter"></splash-cover>
