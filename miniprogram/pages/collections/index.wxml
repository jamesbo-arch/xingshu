<view class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="page-header">
    <view class="header-top">
      <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="page-title serif">我的收藏</text><kefu-fab mode="inline" /></view>
    </view>
    <view class="search-row">
      <view class="search-bar">
        <view class="search-icon ic-search"></view>
        <input
          class="search-input"
          placeholder="搜索收藏的日记"
          placeholder-style="color: #A8A39B; font-size: 28rpx;"
          value="{{search}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
        <view wx:if="{{search}}" class="search-clear ic-close" bindtap="onSearchClear"></view>
      </view>
      <view class="filter-btn {{filtersActive ? 'filter-active' : ''}}" bindtap="onOpenFilter">
        <view class="filter-icon {{filtersActive ? 'ic-filter-w' : 'ic-filter'}}"></view>
        <view wx:if="{{filtersActive}}" class="filter-dot"></view>
      </view>
    </view>
  </view>

  <!-- Diary list -->
  <scroll-view class="diary-list" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onReachBottom" lower-threshold="150" refresher-enabled refresher-background="#FBF7EE" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view wx:if="{{diaries.length === 0}}" class="empty-state">
      <view class="empty-icon ic-bookmark"></view>
      <text class="empty-text">暂无收藏</text>
      <text class="empty-hint">在广场中点击书签即可收藏</text>
    </view>
    <diary-card
      wx:for="{{diaries}}"
      wx:key="id"
      diary="{{item}}"
      show-actions="{{false}}"
      bind:open="onCardOpen"
      bind:like="onCardLike"
      bind:fav="onCardFav"
      bind:share="onCardShare"
    ></diary-card>
    <view class="list-bottom-pad"></view>
  </scroll-view>

  <!-- Filter sheet -->
  <filter-sheet
    visible="{{showFilterSheet}}"
    filters="{{filters}}"
    all-tags="{{allTags}}"
    bind:close="onCloseFilter"
    bind:apply="onApplyFilter"
  ></filter-sheet>

  <!-- Poster sheet -->
  <poster-sheet
    visible="{{showPosterSheet}}"
    diary="{{posterDiary}}"
    bind:close="onClosePoster"
    bind:shared="onShared"
  ></poster-sheet>

  <!-- Member guard -->
  <member-guard
    visible="{{showMemberGuard}}"
    identity="{{userIdentity}}"
    bind:close="onCloseMemberGuard"
    bind:authorize="onGuardAuthorize"
    bind:joinMember="onGuardJoinMember"
  ></member-guard>
</view>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
