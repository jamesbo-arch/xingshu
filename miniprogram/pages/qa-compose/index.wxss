page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

/* ic-back 是背景图类，必须显式给宽高，否则 0×0 不可见 */
.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -12rpx;
}

.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

.compose-body {
  flex: 1;
  overflow: hidden;
  padding: 0 24rpx;
}

.compose-card {
  background: #FFFCF5;
  border-radius: 14px;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.compose-textarea {
  width: 100%;
  min-height: 320rpx;
  font-size: 30rpx;
  line-height: 48rpx;
  color: #2A2723;
}

.compose-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #A8A39B;
  margin-top: 12rpx;
}

.option-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.option-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.option-label {
  font-size: 28rpx;
  color: #2A2723;
}

.option-desc {
  font-size: 22rpx;
  color: #A8A39B;
}

.compose-bottom-pad {
  height: 40rpx;
}

.compose-bar {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(251, 247, 238, 0.92);
  border-top: 1px solid rgba(126, 102, 64, 0.1);
}

.compose-btn {
  flex: 1;
}
