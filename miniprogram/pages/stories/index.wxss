/* 禁用页面级滚动/回弹：仅内部 scroll-view 滚动，锁定顶部标题栏 */
page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Header */
.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

/* Search bar */
.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
  gap: 10rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2A2723;
  height: 40rpx;
}

.search-clear {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.filter-active {
  background: #2A2723;
}

.filter-icon {
  width: 36rpx;
  height: 36rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: #B6452F;
  border-radius: 50%;
  border: 2px solid #FBF7EE;
}

/* 精选筛选：星 + 「精选」竖排塞进同一个 80rpx 圆内，
   这样圆心与漏斗按钮仍在同一水平线上，不会把搜索行撑高 */
.star-btn {
  flex-direction: column;
  gap: 2rpx;
}

.star-icon {
  width: 30rpx;
  height: 30rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.star-label {
  font-size: 20rpx;
  line-height: 1;
  color: #7A746A;
}

.star-label-on {
  color: #2A2723;
  font-weight: 600;
}

/* List */
.story-list {
  flex: 1;
  min-height: 0;
  width: 100%;
  padding: 0 24rpx;
}

.list-bottom-pad {
  height: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #D6D0C2;
}

.empty-text {
  font-size: 28rpx;
  color: #A8A39B;
}

/* FAB */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  transition: bottom 0.25s ease;
  width: 108rpx;
  height: 108rpx;
  background: #2A2723;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(42, 39, 35, 0.32);
  z-index: 30;
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

