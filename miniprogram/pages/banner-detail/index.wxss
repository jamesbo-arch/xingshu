page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

/* ic-back 是背景图类，必须显式给宽高，否则 0×0 不可见 */
.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -12rpx;
}

.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.banner-body {
  flex: 1;
  overflow: hidden;
  padding: 0 24rpx;
}

.banner-hero {
  width: 100%;
  border-radius: 14px;
  display: block;
  margin-bottom: 24rpx;
  background: #EFE7D4;
}

.banner-rich {
  background: #FFFCF5;
  border-radius: 14px;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  padding: 32rpx;
  font-size: 30rpx;
  line-height: 52rpx;
  color: #2A2723;
}

.banner-bottom-pad {
  height: calc(env(safe-area-inset-bottom) + 60rpx);
}
