<view class="page-wrap paper-bg" wx:if="{{activity}}">
  <view style="height: {{statusBarHeight}}px; background: #FBF7EE;"></view>
  <view class="detail-nav">
    <view class="nav-back" bindtap="onBack"><view class="nav-back-icon ic-back"></view></view>
    <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="nav-title serif">{{isPast ? '活動回顧' : '活動詳情'}}</text><kefu-fab mode="inline" /></view>
    <view class="nav-right" bindtap="onOpenPoster"><view class="nav-share-icon ic-share"></view></view>
  </view>

  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="detail-body">
      <view class="act-cover">
        <image wx:if="{{activity.cover_url}}" src="{{activity.cover_url}}" class="act-cover-img" mode="aspectFill"/>
        <text wx:else class="act-cover-char serif">{{activity.title[0]}}</text>
        <text class="act-cover-seal serif">醒書</text>
        <text wx:if="{{isPast}}" class="act-badge act-badge-past">回顾</text>
        <text wx:elif="{{activity.isSignedUp}}" class="act-badge act-badge-signed">已报名</text>
        <text wx:elif="{{isFull}}" class="act-badge act-badge-full">名额已满</text>
        <text wx:else class="act-badge act-badge-open">报名中</text>
      </view>

      <text class="detail-title serif">{{activity.title}}</text>

      <view class="act-info-card">
        <view class="act-meta"><view class="act-meta-icon ic-calendar"></view><text>{{activity.start_time}}{{activity.end_time ? ' – ' + activity.end_time : ''}}</text></view>
        <view class="act-meta"><view class="act-meta-icon ic-pin"></view><text>{{activity.type === 'online' ? '线上 · ' + activity.location : activity.city + ' · ' + activity.location}}</text></view>
        <view class="act-meta"><view class="act-meta-icon ic-users"></view><text>组织方：{{activity.organizer}}</text></view>
        <view wx:if="{{!isPast}}" class="act-progress-row">
          <view class="act-progress"><view class="act-progress-fill" style="width: {{pct}}%"></view></view>
          <text class="act-count">已报名 {{activity.signup_count}}/{{activity.capacity}}</text>
        </view>
        <text wx:if="{{!isPast && activity.signup_deadline}}" class="act-deadline">{{activity.signup_deadline}} 报名截止</text>
      </view>

      <block wx:if="{{!isPast}}">
        <view class="act-section-title serif">活動介紹</view>
        <text class="act-content">{{activity.content}}</text>
      </block>

      <block wx:if="{{isPast && activity.review_content}}">
        <view class="act-section-title serif">回顧</view>
        <text class="act-content">{{activity.review_content}}</text>
        <view wx:if="{{activity.review_images && activity.review_images.length}}" class="act-photo-grid">
          <image
            wx:for="{{activity.review_images}}"
            wx:key="*this"
            class="act-photo"
            src="{{item}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage"
          />
        </view>
      </block>

      <view wx:if="{{activity.images && activity.images.length}}" class="act-photo-grid">
        <image
          wx:for="{{activity.images}}"
          wx:key="*this"
          class="act-photo"
          src="{{item}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="onPreviewImage"
        />
      </view>

      <view class="act-bottom-pad"></view>
    </view>
  </scroll-view>

  <!-- 底部报名栏（仅未结束活动） -->
  <view wx:if="{{!isPast}}" class="act-signup-bar">
    <block wx:if="{{activity.isSignedUp}}">
      <text class="act-signed-text">✓ 已报名，期待相见</text>
      <view class="btn-ghost act-cancel-btn" bindtap="onCancelSignup">取消报名</view>
    </block>
    <view wx:elif="{{isFull}}" class="act-signup-btn disabled">名额已满</view>
    <view wx:else class="act-signup-btn" bindtap="onOpenSignup">报名参加</view>
  </view>

  <!-- 活动海报弹层（v2.2） -->
  <view wx:if="{{showPoster}}">
    <view class="sheet-mask {{_posterShow ? 'mask-show' : ''}}" bindtap="onClosePoster"></view>
    <view class="sheet poster-sheet {{_posterShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">活动海报</text>
      <view class="poster-card">
        <view class="poster-brand serif">醒 書 活 動</view>
        <text class="poster-title serif">{{activity.title}}</text>
        <text class="poster-meta">{{activity.start_time}}</text>
        <text class="poster-meta">{{activity.type === 'online' ? '线上活动' : activity.city + ' · ' + activity.location}}</text>
        <view class="poster-divider"></view>
        <view class="poster-footer">
          <view class="poster-footer-info">
            <text class="poster-signed serif">{{isPast ? '往期回顾' : '已有 ' + activity.signup_count + ' 位醒书人报名'}}</text>
            <text class="poster-hint">长按扫码 · 与同路人相见</text>
          </view>
          <image wx:if="{{qrFileID}}" src="{{qrFileID}}" class="poster-qr" mode="aspectFit"/>
          <view wx:else class="poster-qr poster-qr-loading"><text>生成中</text></view>
        </view>
      </view>
      <view class="poster-actions">
        <view class="btn-ghost poster-btn" bindtap="onSaveQr">保存小程序码</view>
        <view class="act-signup-btn poster-btn" bindtap="onClosePoster">完成</view>
      </view>
    </view>
  </view>

  <!-- 报名表单弹层 -->
  <view wx:if="{{showSignup}}">
    <view class="sheet-mask {{_sheetShow ? 'mask-show' : ''}}" bindtap="onCloseSignup"></view>
    <view class="sheet signup-sheet {{_sheetShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">报名 · {{activity.title}}</text>
      <text class="signup-time">{{activity.start_time}}</text>
      <text class="signup-label">你的称呼</text>
      <view class="signup-value">{{signupName || '未填写'}}</view>
      <text class="signup-label">联系方式</text>
      <view class="signup-value {{signupContact ? '' : 'empty'}}">{{signupContact || '未填写'}}</view>
      <view class="act-signup-btn signup-submit" bindtap="onSubmitSignup">确认报名</view>
      <text class="signup-privacy">以上取自你的个人资料，如需修改请到「会员中心 → 编辑资料」。报名信息仅用于本次活动组织，不会公开</text>
    </view>
  </view>

  <!-- 完善资料弹层（报名前若缺姓名/电话，填完自动继续报名并同步到个人资料）-->
  <view wx:if="{{showProfileComplete}}">
    <view class="sheet-mask {{_pcShow ? 'mask-show' : ''}}" bindtap="onClosePc"></view>
    <view class="sheet signup-sheet {{_pcShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">完善资料后报名</text>
      <text class="signup-time">报名需要你的姓名和联系电话</text>
      <text class="signup-label">姓名 *</text>
      <input class="signup-input" placeholder="你的真实姓名" value="{{pcName}}" bindinput="onPcNameInput" maxlength="20"/>
      <text class="signup-label">联系电话 *</text>
      <input class="signup-input" type="number" placeholder="手机号，便于活动通知" value="{{pcPhone}}" bindinput="onPcPhoneInput" maxlength="11"/>
      <view class="act-signup-btn signup-submit" bindtap="onSavePcAndSignup">保存并继续报名</view>
      <text class="signup-privacy">将同步到你的个人资料；仅用于活动组织与通知，不会公开</text>
    </view>
  </view>
</view>

<!-- v2.3 微信登录弹窗：活动详情需轻授权，activity 为空时也需可见，故置于根节点之外 -->
<login-sheet
  visible="{{showLoginSheet}}"
  subtitle="登录后即可查看活动详情并报名，加入一群认真生活的人。"
  bind:close="onLoginClose"
  bind:success="onLoginSuccess"
></login-sheet>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
