<view class="page-wrap paper-bg" wx:if="{{activity}}">
  <view style="height: {{statusBarHeight}}px; background: #FBF7EE;"></view>
  <view class="detail-nav" style="padding-right: {{capsulePad}}px;">
    <view class="nav-back" bindtap="onBack"><view class="nav-back-icon ic-back"></view></view>
    <text class="nav-title serif">{{isPast ? '活動回顧' : '活動詳情'}}</text>
    <view class="nav-right" bindtap="onOpenPoster"><view class="nav-share-icon ic-share"></view></view>
  </view>

  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onPostsMore" lower-threshold="150" scroll-into-view="{{scrollInto}}">
    <view class="detail-body">
      <!-- 标题行：标题 + 状态徽章（已报名可点开报名名单） -->
      <view class="detail-title-row">
        <text class="detail-title serif">{{activity.title}}</text>
        <text wx:if="{{isPast}}" class="title-badge act-badge-past">回顾</text>
        <text wx:elif="{{activity.isSignedUp}}" class="title-badge act-badge-signed" bindtap="onShowSignups">已报名 ›</text>
        <text wx:elif="{{signupClosed}}" class="title-badge act-badge-past">报名已截止</text>
        <text wx:elif="{{isFull}}" class="title-badge act-badge-full">名额已满</text>
        <text wx:else class="title-badge act-badge-open">报名中</text>
      </view>

      <view class="act-info-card">
        <view class="act-meta"><view class="act-meta-icon ic-calendar"></view><text>{{invite.timeText}}</text></view>
        <view class="act-meta"><view class="act-meta-icon ic-pin"></view>
          <!-- 线上：会议号仅报名可见（后端掩码 + locationLocked 标记）；线下：有坐标时点击打开地图 -->
          <text wx:if="{{activity.type === 'online'}}">线上{{activity.locationLocked ? ' · 会议号报名后可见' : (activity.location ? ' · 腾讯会议 ' + activity.location : '')}}</text>
          <text wx:else class="{{activity.latitude ? 'act-addr-link' : ''}}" bindtap="onOpenMap">{{activity.city}} · {{activity.location}}{{activity.latitude ? ' ›' : ''}}</text>
        </view>
        <view class="act-meta"><text class="act-meta-yen">¥</text><text>{{feeText}}</text></view>
        <view wx:if="{{!isPast}}" class="act-progress-row">
          <view class="act-progress"><view class="act-progress-fill" style="width: {{pct}}%"></view></view>
          <text class="act-count">已报名 {{activity.signup_count}}/{{activity.capacity}}</text>
        </view>
        <text wx:if="{{!isPast && activity.signup_deadline}}" class="act-deadline">{{activity.signup_deadline}} 报名截止</text>
      </view>

      <block wx:if="{{!isPast}}">
        <view class="act-section-title serif">活動介紹</view>
        <text class="act-content">{{activity.content}}</text>
      </block>

      <block wx:if="{{isPast && activity.review_content}}">
        <view class="act-section-title serif">回顧</view>
        <text class="act-content">{{activity.review_content}}</text>
        <view wx:if="{{activity.review_images && activity.review_images.length}}" class="act-photo-grid">
          <image
            wx:for="{{activity.review_images}}"
            wx:key="*this"
            class="act-photo"
            src="{{item}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage"
          />
        </view>
      </block>

      <view wx:if="{{activity.images && activity.images.length}}" class="act-photo-grid">
        <image
          wx:for="{{activity.images}}"
          wx:key="*this"
          class="act-photo"
          src="{{item}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="onPreviewImage"
        />
      </view>

      <!-- 現場分享：已报名者活动开始后可发（canPost），所有登录用户可看 -->
      <block wx:if="{{postsTotal > 0 || activity.canPost}}">
        <view id="postsAnchor" class="act-section-title serif" style="margin-top: 40rpx;">現場分享{{postsTotal ? ' · ' + postsTotal : ''}}</view>
        <view wx:for="{{posts}}" wx:key="id" class="post-item">
          <view class="post-head">
            <image wx:if="{{item.avatar_url}}" class="post-avatar-img" src="{{item.avatar_url}}" mode="aspectFill"/>
            <view wx:else class="post-avatar" style="background-color: {{item.avatarColor}};"><text>{{item.initial}}</text></view>
            <view class="post-head-info">
              <text class="post-nick">{{item.nickname}}</text>
              <text class="post-time">{{item.timeText}}</text>
            </view>
            <view class="post-like {{item.isLiked ? 'post-like-on' : ''}}" data-id="{{item.id}}" catchtap="onLikePost">
              <view class="hicon"></view><text wx:if="{{item.likeCount}}" class="post-like-n">{{item.likeCount}}</text>
            </view>
            <text wx:if="{{item.isMine}}" class="post-del" data-id="{{item.id}}" catchtap="onDeletePost">删除</text>
          </view>
          <text wx:if="{{item.content}}" class="post-content" user-select>{{item.content}}</text>
          <view wx:if="{{item.images.length}}" class="act-photo-grid post-grid">
            <image
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:for-index="ii"
              wx:key="*this"
              class="act-photo"
              src="{{img}}"
              mode="aspectFill"
              data-pidx="{{index}}"
              data-idx="{{ii}}"
              catchtap="onPreviewPostImage"
            />
          </view>
        </view>
        <view wx:if="{{postsHasMore}}" class="post-more" bindtap="onPostsMore">加载更多</view>
      </block>

      <view class="act-bottom-pad"></view>
    </view>
  </scroll-view>

  <!-- 现场分享相机浮窗：已报名且活动进行中（canPost）时出现，替代底部报名状态行 -->
  <view wx:if="{{activity.canPost}}" class="act-share-fab" bindtap="onOpenPostSheet">
    <view class="act-share-fab-icon ic-camera-w"></view>
  </view>

  <!-- 底部报名栏（未结束、且非「可分享现场」态时显示） -->
  <view wx:if="{{!isPast && !activity.canPost}}" class="act-signup-bar">
    <block wx:if="{{activity.isSignedUp}}">
      <text class="act-signed-text">✓ 已报名，期待相见</text>
      <!-- 报名已关闭（过截止/已开始）则不再提供取消入口 -->
      <view wx:if="{{!signupClosed}}" class="btn-ghost act-cancel-btn" bindtap="onCancelSignup">取消报名</view>
    </block>
    <view wx:elif="{{signupClosed}}" class="act-signup-btn disabled">报名已截止</view>
    <view wx:elif="{{isFull}}" class="act-signup-btn disabled">名额已满</view>
    <view wx:else class="act-signup-btn" bindtap="onOpenSignup">报名参加</view>
  </view>

  <!-- 活动邀请函弹层：主题化预览 + 保存/分享成图（码带分享人参数，扫码授权即绑定推荐人） -->
  <view wx:if="{{showPoster}}">
    <view class="sheet-mask {{_posterShow ? 'mask-show' : ''}}" bindtap="onClosePoster"></view>
    <view class="sheet poster-sheet {{_posterShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">活動邀請函</text>
      <scroll-view scroll-y class="inv-preview-scroll">
        <view class="inv-card inv-{{invite.key}}">
          <view class="inv-body">
            <text class="inv-tag">{{invite.tagText}}</text>
            <text class="inv-kicker">{{invite.kicker}}</text>
            <text class="inv-title serif">{{activity.title}}</text>
            <text class="inv-intro">{{invite.intro}}</text>
            <view wx:if="{{activity.images && activity.images.length}}" class="inv-images">
              <image wx:for="{{activity.images}}" wx:key="*this" src="{{item}}" mode="widthFix" class="inv-image"/>
            </view>
            <view class="inv-info">
              <view class="inv-row"><text class="inv-b">活动时间</text><text class="inv-v">{{invite.timeText}}</text></view>
              <view class="inv-row"><text class="inv-b">参与方式</text><text class="inv-v">{{invite.joinText}}</text></view>
              <view class="inv-row"><text class="inv-b">报名限额</text><text class="inv-v">{{invite.quotaText}}</text></view>
              <view class="inv-row"><text class="inv-b">活动费用</text><text class="inv-v">{{invite.feeText}}</text></view>
            </view>
            <view class="inv-cta">
              <view class="inv-cta-text"><text>长按识别小程序码</text><text>报名参加</text></view>
              <image wx:if="{{qrFileID}}" src="{{qrFileID}}" class="inv-qr" mode="aspectFit"/>
              <view wx:else class="inv-qr inv-qr-loading"><text>生成中</text></view>
            </view>
          </view>
          <view class="inv-foot">
            <view class="invf-logo">
              <text class="invf-name serif">醒书咨询</text>
              <text class="invf-en">XINGSHU CONSULTING</text>
            </view>
            <text class="invf-desc">醒书咨询，一家专注经典文化与现代生活深度对话的机构，为中小企业和个人提供发展咨询服务。</text>
          </view>
        </view>
      </scroll-view>
      <view class="poster-actions">
        <view class="btn-ghost poster-btn" bindtap="onSaveInvite">保存图片</view>
        <view class="act-signup-btn poster-btn" bindtap="onShareInvite">分享给朋友</view>
      </view>
    </view>
  </view>

  <!-- 邀请函离屏画布（Canvas 2D，导出 750×1180 成图） -->
  <canvas id="inv-canvas" type="2d" class="inv-canvas"></canvas>

  <!-- 报名表单弹层 -->
  <view wx:if="{{showSignup}}">
    <view class="sheet-mask {{_sheetShow ? 'mask-show' : ''}}" bindtap="onCloseSignup"></view>
    <view class="sheet signup-sheet {{_sheetShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">报名 · {{activity.title}}</text>
      <text class="signup-time">{{activity.start_time}}</text>
      <text class="signup-label">你的称呼</text>
      <view class="signup-value">{{signupName || '未填写'}}</view>
      <text class="signup-label">联系方式</text>
      <view class="signup-value {{signupContact ? '' : 'empty'}}">{{signupContact || '未填写'}}</view>
      <view class="act-signup-btn signup-submit" bindtap="onSubmitSignup">确认报名</view>
      <text class="signup-privacy">以上取自你的个人资料，如需修改请到「会员中心 → 编辑资料」。报名信息仅用于本次活动组织，不会公开</text>
    </view>
  </view>

  <!-- 报名名单弹层（仅已报名可开，后端二次校验） -->
  <view wx:if="{{showSignups}}">
    <view class="sheet-mask {{_suShow ? 'mask-show' : ''}}" bindtap="onCloseSignups"></view>
    <view class="sheet signup-sheet {{_suShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">已报名 · {{signups.length}} 人</text>
      <scroll-view scroll-y class="su-list">
        <view wx:for="{{signups}}" wx:key="index" class="su-row">
          <text class="su-idx">{{index + 1}}</text>
          <image wx:if="{{item.avatar_url}}" class="su-ava-img" src="{{item.avatar_url}}" mode="aspectFill"/>
          <view wx:else class="su-ava" style="background-color: {{item.avatarColor}};"><text>{{item.initial}}</text></view>
          <text class="su-name">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 现场分享发布弹层 -->
  <view wx:if="{{showPostSheet}}">
    <view class="sheet-mask {{_postShow ? 'mask-show' : ''}}" bindtap="onClosePostSheet"></view>
    <view class="sheet signup-sheet {{_postShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">分享现场</text>
      <textarea
        class="post-textarea"
        placeholder="记录此刻的所见所感…"
        placeholder-style="color: #A8A39B;"
        maxlength="1000"
        value="{{postContent}}"
        bindinput="onPostInput"
        show-confirm-bar="{{false}}"
      />
      <view class="post-pick-grid">
        <view wx:for="{{postImages}}" wx:key="*this" class="post-pick-cell">
          <image class="post-pick-thumb" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewPickImage"/>
          <view class="post-pick-remove" data-index="{{index}}" catchtap="onRemovePostImage"><text>×</text></view>
        </view>
        <view wx:if="{{postImages.length < 9}}" class="post-pick-add" bindtap="onAddPostImage">
          <text class="post-pick-add-icon">+</text>
          <text class="post-pick-add-text">照片</text>
        </view>
      </view>
      <view class="act-signup-btn signup-submit" bindtap="onSubmitPost">发布</view>
    </view>
  </view>

  <!-- 完善资料弹层（报名前若缺姓名/电话，填完自动继续报名并同步到个人资料）-->
  <view wx:if="{{showProfileComplete}}">
    <view class="sheet-mask {{_pcShow ? 'mask-show' : ''}}" bindtap="onClosePc"></view>
    <view class="sheet signup-sheet {{_pcShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="signup-title serif">完善资料后报名</text>
      <text class="signup-time">报名需要你的姓名和联系电话</text>
      <text class="signup-label">姓名 *</text>
      <input class="signup-input" placeholder="你的真实姓名" value="{{pcName}}" bindinput="onPcNameInput" maxlength="20"/>
      <text class="signup-label">联系电话 *</text>
      <input class="signup-input" type="number" placeholder="手机号，便于活动通知" value="{{pcPhone}}" bindinput="onPcPhoneInput" maxlength="11"/>
      <view class="act-signup-btn signup-submit" bindtap="onSavePcAndSignup">保存并继续报名</view>
      <text class="signup-privacy">将同步到你的个人资料；仅用于活动组织与通知，不会公开</text>
    </view>
  </view>
</view>

<!-- 未登录占位页：登录墙拦截中（needLogin）时渲染，杜绝白屏；按钮为点击时触发的可靠路径 -->
<view wx:if="{{!activity && needLogin}}" class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px; background: #FBF7EE;"></view>
  <view class="detail-nav" style="padding-right: {{capsulePad}}px;">
    <view class="nav-back" bindtap="onBack"><view class="nav-back-icon ic-back"></view></view>
    <text class="nav-title serif">活動詳情</text>
  </view>
  <view class="act-wall">
    <text class="act-wall-icon serif">醒</text>
    <text class="act-wall-title">登录后即可查看活动详情</text>
    <text class="act-wall-hint">了解活动安排、报名参加、查看现场分享</text>
    <view class="act-wall-btn" bindtap="onWallLogin">微信登录</view>
  </view>
</view>

<!-- v2.3 微信登录弹窗：活动详情需轻授权，activity 为空时也需可见，故置于根节点之外 -->
<login-sheet
  visible="{{showLoginSheet}}"
  subtitle="登录后即可查看活动详情并报名，加入一群认真生活的人。"
  bind:close="onLoginClose"
  bind:success="onLoginSuccess"
></login-sheet>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
