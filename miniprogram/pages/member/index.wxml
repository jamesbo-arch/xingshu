<view class="page-wrap paper-bg" wx:if="{{user}}">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Page header -->
  <view class="page-header">
    <text class="page-title serif">会员中心</text>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="page-scroll">

    <!-- ===== GUEST STATE ===== -->
    <block wx:if="{{user.identity === 'guest'}}">
      <view class="identity-card guest-card">
        <view class="guest-avatar">
          <text class="guest-question">?</text>
        </view>
        <view class="identity-info">
          <text class="identity-label-badge guest-badge">未授权</text>
          <text class="identity-hint">授权后可解锁完整功能</text>
        </view>
      </view>

      <view class="auth-section">
        <view class="btn-primary auth-btn" bindtap="onAuthorize">
          <text class="btn-icon">⊙</text>
          <text>微信授权手机号 · 解锁完整功能</text>
        </view>
        <text class="auth-hint">授权仅用于身份核验，不会公开您的信息</text>
      </view>
    </block>

    <!-- ===== AUTHED STATE ===== -->
    <block wx:elif="{{user.identity === 'authed'}}">
      <view class="identity-card authed-card">
        <view class="avatar-wrap-click" bindtap="onShowProfileSheet">
          <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="avatar lg avatar-real" mode="aspectFill" />
          <view wx:else class="avatar lg" style="background-color: {{avatarColor}};">
            <text>{{avatarInitial}}</text>
          </view>
          <view class="avatar-edit-badge"><text>换</text></view>
        </view>
        <view class="identity-info">
          <view class="identity-name-row">
            <text class="identity-name">{{user.nickname}}</text>
            <text class="identity-label-badge authed-badge">用户</text>
          </view>
          <text class="identity-phone">{{user.phone}}</text>
        </view>
      </view>

      <view class="member-cta-card" bindtap="onShowPurchaseSheet">
        <view class="cta-left">
          <text class="cta-icon">★</text>
          <view>
            <text class="cta-title">如何成为会员</text>
            <text class="cta-desc">解锁全部会员权益</text>
          </view>
        </view>
        <text class="cta-arrow">→</text>
      </view>

      <view class="section-card">
        <view class="section-header">
          <text class="section-title">个人信息</text>
          <text class="section-action" bindtap="onShowProfileSheet">编辑 →</text>
        </view>
        <view class="info-row">
          <text class="info-label">昵称</text>
          <text class="info-value">{{user.nickname}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">真实姓名</text>
          <text class="info-value {{user.realName ? '' : 'placeholder'}}">{{user.realName || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">手机号</text>
          <text class="info-value">{{user.phone}}</text>
        </view>
      </view>

      <view class="section-card stats-card">
        <view class="stats-grid">
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.diaries}}</text>
            <text class="stat-label">日记</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.likes}}</text>
            <text class="stat-label">获赞</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.favorites}}</text>
            <text class="stat-label">收藏</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.comments + user.stats.shares}}</text>
            <text class="stat-label">互动</text>
          </view>
        </view>
      </view>

      <view class="section-card benefits-card">
        <text class="section-title" style="margin-bottom: 20rpx; display: block;">会员权益</text>
        <view wx:for="{{benefits}}" wx:key="text" class="benefit-item dimmed">
          <text class="benefit-icon">{{item.icon}}</text>
          <text class="benefit-text">{{item.text}}</text>
          <text class="benefit-lock">🔒</text>
        </view>
      </view>
    </block>

    <!-- ===== MEMBER STATE ===== -->
    <block wx:elif="{{user.identity === 'member'}}">
      <view class="identity-card member-card">
        <view class="avatar-wrap-click" bindtap="onShowProfileSheet">
          <view class="member-avatar-wrap">
            <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="avatar lg avatar-real" mode="aspectFill" />
            <view wx:else class="avatar lg" style="background-color: {{avatarColor}};">
              <text>{{avatarInitial}}</text>
            </view>
            <view class="member-avatar-badge"><text>会</text></view>
          </view>
          <view class="avatar-edit-badge"><text>换</text></view>
        </view>
        <view class="identity-info">
          <view class="identity-name-row">
            <text class="identity-name member-name">{{user.nickname}}</text>
            <text class="identity-label-badge member-badge">会员</text>
          </view>
          <text class="identity-phone">{{user.phone}}</text>
          <view class="member-until">
            <text class="until-text">有效至 {{user.memberUntil}}</text>
          </view>
        </view>
        <view class="member-seal">
          <text class="member-seal-text serif">会員之印</text>
        </view>
      </view>

      <view class="days-card">
        <view class="days-left-row">
          <view>
            <text class="days-num">{{user.daysLeft}}</text>
            <text class="days-unit">天</text>
          </view>
          <text class="days-label">会员剩余天数</text>
        </view>
        <view class="renew-btn" bindtap="onShowPurchaseSheet">
          <text>如何续费 →</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-header">
          <text class="section-title">个人信息</text>
          <text class="section-action" bindtap="onShowProfileSheet">编辑 →</text>
        </view>
        <view class="info-row">
          <text class="info-label">昵称</text>
          <text class="info-value">{{user.nickname}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">真实姓名</text>
          <text class="info-value {{user.realName ? '' : 'placeholder'}}">{{user.realName || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">手机号</text>
          <text class="info-value">{{user.phone}}</text>
        </view>
      </view>

      <view class="section-card stats-card">
        <view class="stats-grid">
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.diaries}}</text>
            <text class="stat-label">日记</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.likes}}</text>
            <text class="stat-label">获赞</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.favorites}}</text>
            <text class="stat-label">收藏</text>
          </view>
          <view class="stat-cell">
            <text class="stat-num">{{user.stats.comments + user.stats.shares}}</text>
            <text class="stat-label">互动</text>
          </view>
        </view>
      </view>

      <view class="section-card" wx:if="{{user.latestOrder}}">
        <text class="section-title" style="margin-bottom: 16rpx; display: block;">最近订单</text>
        <view class="order-card">
          <view class="order-row">
            <text class="order-label">订单号</text>
            <text class="order-value mono">{{user.latestOrder.id}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">金额</text>
            <text class="order-value">¥{{user.latestOrder.amount}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">方式</text>
            <text class="order-value">{{user.latestOrder.method}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">创建人</text>
            <text class="order-value">{{user.latestOrder.createdBy}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">时间</text>
            <text class="order-value">{{user.latestOrder.createdAt}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">状态</text>
            <text class="order-status paid">已支付</text>
          </view>
        </view>
      </view>

      <view class="section-card benefits-card">
        <text class="section-title" style="margin-bottom: 20rpx; display: block;">会员权益</text>
        <view wx:for="{{benefits}}" wx:key="text" class="benefit-item">
          <text class="benefit-icon">{{item.icon}}</text>
          <text class="benefit-text">{{item.text}}</text>
          <text class="benefit-check">✓</text>
        </view>
      </view>
    </block>

    <view class="bottom-pad"></view>
  </scroll-view>

  <!-- Profile edit sheet -->
  <view wx:if="{{showProfileSheet}}">
    <view class="sheet-mask" bindtap="onCloseProfileSheet"></view>
    <view class="sheet profile-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="sheet-sheet-title serif">编辑资料</text>

      <!-- Avatar picker -->
      <button class="avatar-picker-row" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{editAvatarUrl}}" src="{{editAvatarUrl}}" class="avatar-picker-img" mode="aspectFill" />
        <view wx:else class="avatar-picker-placeholder" style="background-color: {{avatarColor}};">
          <text class="avatar-picker-initial">{{avatarInitial}}</text>
        </view>
        <text class="avatar-picker-label">更换头像</text>
        <text class="avatar-picker-arrow">›</text>
      </button>

      <view class="profile-divider"></view>

      <view class="profile-field">
        <text class="field-label">昵称</text>
        <input
          type="nickname"
          class="field-input"
          placeholder="请输入昵称"
          placeholder-style="color: #A8A39B;"
          value="{{editNickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>

      <view class="profile-field">
        <text class="field-label">真实姓名</text>
        <input
          class="field-input"
          placeholder="选填，便于运营核对身份"
          placeholder-style="color: #A8A39B;"
          value="{{editRealName}}"
          bindinput="onRealNameInput"
          maxlength="20"
        />
      </view>

      <view class="profile-btns">
        <view class="btn-ghost profile-btn" bindtap="onCloseProfileSheet">取消</view>
        <view class="btn-primary profile-btn" bindtap="onSaveProfile">保存</view>
      </view>
      <view class="safe-bottom"></view>
    </view>
  </view>

  <!-- Purchase sheet -->
  <view wx:if="{{showPurchaseSheet}}">
    <view class="sheet-mask" bindtap="onClosePurchaseSheet"></view>
    <view class="sheet purchase-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="sheet-sheet-title serif">开通会员</text>
      <text class="purchase-subtitle">联系运营完成开通，每年 ¥365</text>

      <view class="steps-list">
        <view wx:for="{{purchaseSteps}}" wx:key="num" class="step-item">
          <view class="step-num-wrap">
            <text class="step-num serif">{{item.num}}</text>
          </view>
          <view class="step-content">
            <text class="step-title">{{item.title}}</text>
            <text class="step-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="admin-card" wx:if="{{adminContact}}">
        <view class="admin-row">
          <text class="admin-label">联系人</text>
          <text class="admin-value">{{adminContact.name}}</text>
        </view>
        <view class="admin-row">
          <text class="admin-label">微信号</text>
          <view class="admin-wechat-row">
            <text class="admin-value mono">{{adminContact.wechat}}</text>
            <text class="copy-btn" bindtap="onCopyWechat">复制</text>
          </view>
        </view>
        <view class="admin-row">
          <text class="admin-label">在线时间</text>
          <text class="admin-value">{{adminContact.hours}}</text>
        </view>
        <text class="admin-note">{{adminContact.note}}</text>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </view>
</view>
