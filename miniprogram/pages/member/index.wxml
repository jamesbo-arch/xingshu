<view class="page-wrap paper-bg" wx:if="{{user}}">
  <view style="height: {{statusBarHeight}}px;"></view>

  <view class="page-header">
    <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="page-title serif">醒書會員</text><kefu-fab /></view>
  </view>

  <!-- 固定顶部：身份卡（会员额外含有效期卡；guest 不显示卡片，仅居中登录引导） -->
  <view class="member-top">
    <block wx:if="{{user.identity === 'authed'}}">
      <view class="identity-card authed-card">
        <view class="avatar-wrap-click" bindtap="onShowProfileSheet">
          <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="avatar lg avatar-real" mode="aspectFill" />
          <view wx:else class="avatar lg" style="background-color: {{avatarColor}};">
            <text>{{avatarInitial}}</text>
          </view>
          <view class="avatar-edit-badge"><text>换</text></view>
        </view>
        <view class="identity-info">
          <view class="identity-name-row">
            <text class="identity-name">{{user.nickname}}</text>
            <text class="identity-label-badge authed-badge">用户</text>
          </view>
          <text class="identity-phone">{{user.phone}}</text>
        </view>
        <view class="card-settings-btn" catchtap="onOpenSettings">
          <view class="card-settings-icon"></view>
        </view>
      </view>
    </block>
    <block wx:elif="{{user.identity === 'member'}}">
      <view class="identity-card member-card">
        <view class="avatar-wrap-click" bindtap="onShowProfileSheet">
          <view class="member-avatar-wrap">
            <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="avatar lg avatar-real" mode="aspectFill" />
            <view wx:else class="avatar lg" style="background-color: {{avatarColor}};">
              <text>{{avatarInitial}}</text>
            </view>
            <view class="member-avatar-badge"><text>会</text></view>
          </view>
          <view class="avatar-edit-badge"><text>换</text></view>
        </view>
        <view class="identity-info">
          <view class="identity-name-row">
            <text class="identity-name member-name">{{user.nickname}}</text>
            <text class="identity-label-badge member-badge">会员</text>
          </view>
          <text class="identity-phone">{{user.phone}}</text>
          <text class="member-until-text">有效至 {{user.memberUntil}}</text>
        </view>
        <view class="card-settings-btn" catchtap="onOpenSettings">
          <view class="card-settings-icon"></view>
        </view>
      </view>

      <view class="days-renew-card">
        <view class="days-content">
          <view class="days-num-row">
            <text class="days-num serif">{{user.daysLeft || 0}}</text>
            <text class="days-unit"> 天</text>
          </view>
          <text class="days-desc-label">会员剩余天数</text>
        </view>
        <view class="renew-btn" bindtap="onShowPurchaseSheet">
          <text>如何续费 →</text>
        </view>
      </view>
    </block>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="page-scroll">

    <!-- ===== GUEST STATE ===== -->
    <block wx:if="{{user.identity === 'guest'}}">

      <!-- 未登录引导：与活动详情登录页同风格（居中构图 + 印章红圆角按钮） -->
      <view class="guest-wall">
        <text class="guest-wall-icon serif">醒</text>
        <text class="guest-wall-title">登录后解锁完整功能</text>
        <text class="guest-wall-hint">阅读故事全文、点赞评论收藏、报名醒书活动</text>
        <view class="guest-wall-btn" bindtap="onAuthorize">微信登录</view>
        <text class="auth-hint">仅获取你的微信身份标识，不涉及手机号</text>
      </view>

    </block>

    <!-- ===== AUTHED STATE ===== -->
    <block wx:elif="{{user.identity === 'authed'}}">

      <view class="member-join-card">
        <view class="member-join-header">
          <text class="member-join-title serif">如何成为会员</text>
          <text class="member-join-price">线下开通 · ¥365 / 年</text>
        </view>
        <text class="member-join-desc">本产品暂不支持小程序在线支付。请联系管理员转账后，由管理员在后台为您开通会员，开通后此页面将自动更新状态。</text>
        <view class="btn-primary member-join-btn" bindtap="onShowPurchaseSheet">
          <text>查看开通方式</text>
        </view>
      </view>

      <view class="section-header-row">
        <text class="section-label serif">个人资料</text>
        <text class="section-action" bindtap="onShowProfileSheet">编辑 →</text>
      </view>
      <view class="section-card">
        <view class="info-row">
          <text class="info-label">昵称</text>
          <text class="info-value">{{user.nickname}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">真实姓名</text>
          <text class="info-value {{user.realName ? '' : 'empty'}}">{{user.realName || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">性别</text>
          <text class="info-value {{user.gender ? '' : 'empty'}}">{{genderLabel}}</text>
        </view>
        <view class="info-row no-border">
          <text class="info-label">手机号</text>
          <text class="info-value muted">{{user.phone}}</text>
        </view>
      </view>

      <!-- 我的收藏入口（非会员无故事/问答可写，故只给收藏一行） -->
      <view class="section-card">
        <view class="settings-row no-border" bindtap="onOpenCollections">
          <view class="entry-main">
            <view class="entry-icon ic-bookmark"></view>
            <text class="settings-row-text">我的收藏</text>
          </view>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
      </view>

      <view class="section-header-row">
        <text class="section-label serif">互动统计</text>
      </view>
      <view class="stats-grid">
        <view class="stat-box">
          <text class="stat-box-label">已写故事</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.stories || 0}}</text>
            <text class="stat-box-unit">篇</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">获赞</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.likes || 0}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">被收藏</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.favorites || 0}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">评论与转发</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{(user.stats.comments || 0) + (user.stats.shares || 0)}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
      </view>

      <view class="section-header-row">
        <text class="section-label serif">会员权益</text>
      </view>
      <view class="section-card benefits-card">
        <view wx:for="{{benefits}}" wx:key="title" class="benefit-item dimmed">
          <text class="benefit-diamond">✦</text>
          <view class="benefit-body">
            <text class="benefit-title">{{item.title}}</text>
            <text wx:if="{{item.desc}}" class="benefit-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

    </block>

    <!-- ===== MEMBER STATE ===== -->
    <block wx:elif="{{user.identity === 'member'}}">

      <view class="section-header-row">
        <text class="section-label serif">个人资料</text>
        <text class="section-action" bindtap="onShowProfileSheet">编辑 →</text>
      </view>
      <view class="section-card">
        <view class="info-row">
          <text class="info-label">昵称</text>
          <text class="info-value">{{user.nickname}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">真实姓名</text>
          <text class="info-value {{user.realName ? '' : 'empty'}}">{{user.realName || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">性别</text>
          <text class="info-value {{user.gender ? '' : 'empty'}}">{{genderLabel}}</text>
        </view>
        <view class="info-row no-border">
          <text class="info-label">手机号</text>
          <text class="info-value muted">{{user.phone}}</text>
        </view>
      </view>

      <!-- 我的内容入口（v2.0：我的故事、我的问答由底部页签收进醒书会员） -->
      <view class="section-card">
        <view class="settings-row" bindtap="onOpenMine">
          <view class="entry-main">
            <view class="entry-icon ic-pen"></view>
            <text class="settings-row-text">我的故事</text>
          </view>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
        <view class="settings-row" bindtap="onOpenMyQa">
          <view class="entry-main">
            <view class="entry-icon ic-qa"></view>
            <text class="settings-row-text">我的问答</text>
          </view>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
        <view class="settings-row no-border" bindtap="onOpenCollections">
          <view class="entry-main">
            <view class="entry-icon ic-bookmark"></view>
            <text class="settings-row-text">我的收藏</text>
          </view>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
      </view>

      <view class="section-header-row">
        <text class="section-label serif">互动统计</text>
      </view>
      <view class="stats-grid">
        <view class="stat-box">
          <text class="stat-box-label">已写故事</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.stories || 0}}</text>
            <text class="stat-box-unit">篇</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">获赞</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.likes || 0}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">被收藏</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{user.stats.favorites || 0}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
        <view class="stat-box">
          <text class="stat-box-label">评论与转发</text>
          <view class="stat-box-value-row">
            <text class="stat-box-num serif">{{(user.stats.comments || 0) + (user.stats.shares || 0)}}</text>
            <text class="stat-box-unit">次</text>
          </view>
        </view>
      </view>

      <block wx:if="{{user.latestOrder}}">
        <view class="section-header-row">
          <text class="section-label serif">最近订单</text>
        </view>
        <view class="section-card">
          <view class="order-header-row">
            <view class="order-id-group">
              <text class="order-id-label">订单号</text>
              <text class="order-id-value mono">{{user.latestOrder.id}}</text>
            </view>
            <text class="order-status paid">已支付</text>
          </view>
          <view class="order-meta-grid">
            <view class="order-meta-cell">
              <text class="order-meta-key">金额</text>
              <text class="order-meta-val">¥{{user.latestOrder.amount}}</text>
            </view>
            <view class="order-meta-cell">
              <text class="order-meta-key">方式</text>
              <text class="order-meta-val">{{user.latestOrder.method}}</text>
            </view>
            <view class="order-meta-cell order-meta-full">
              <text class="order-meta-key">录入</text>
              <text class="order-meta-val">{{user.latestOrder.createdBy}} · {{user.latestOrder.createdAt}}</text>
            </view>
          </view>
        </view>
      </block>

      <view class="section-header-row">
        <text class="section-label serif">会员权益</text>
      </view>
      <view class="section-card benefits-card">
        <view wx:for="{{benefits}}" wx:key="title" class="benefit-item">
          <text class="benefit-diamond active">✦</text>
          <view class="benefit-body">
            <text class="benefit-title">{{item.title}}</text>
            <text wx:if="{{item.desc}}" class="benefit-desc">{{item.desc}}</text>
          </view>
          <view class="benefit-check ic-check-g"></view>
        </view>
      </view>

    </block>

    <!-- 醒书咨询图（随内容滚动；未登录态保持简洁不展示） -->
    <view wx:if="{{user.identity !== 'guest'}}" class="consulting-banner">
      <image class="consulting-img" src="/images/consulting-banner.png" mode="widthFix" />
    </view>

    <view class="bottom-pad"></view>
  </scroll-view>

  <!-- v2.3 微信登录弹窗 -->
  <login-sheet
    visible="{{showLoginSheet}}"
    bind:close="onLoginClose"
    bind:success="onLoginSuccess"
  ></login-sheet>

  <!-- Profile edit sheet -->
  <view wx:if="{{showProfileSheet}}">
    <view class="sheet-mask" bindtap="onCloseProfileSheet"></view>
    <view class="sheet profile-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="sheet-title serif">编辑资料</text>

      <button class="avatar-picker-row" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{editAvatarUrl}}" src="{{editAvatarUrl}}" class="avatar-picker-img" mode="aspectFill" />
        <view wx:else class="avatar-picker-placeholder" style="background-color: {{avatarColor}};">
          <text class="avatar-picker-initial">{{avatarInitial}}</text>
        </view>
        <text class="avatar-picker-label">更换头像</text>
        <view class="avatar-picker-arrow ic-chevron"></view>
      </button>

      <view class="profile-divider"></view>

      <view class="profile-field">
        <text class="field-label">昵称</text>
        <input
          type="nickname"
          class="field-input"
          placeholder="请输入昵称"
          placeholder-style="color: #A8A39B;"
          value="{{editNickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>

      <view class="profile-field">
        <text class="field-label">真实姓名</text>
        <input
          class="field-input"
          placeholder="选填，便于运营核对身份"
          placeholder-style="color: #A8A39B;"
          value="{{editRealName}}"
          bindinput="onRealNameInput"
          maxlength="20"
        />
      </view>

      <view class="profile-field">
        <text class="field-label">性别</text>
        <view class="gender-options">
          <view
            wx:for="{{genderOptions}}"
            wx:key="key"
            class="gender-option {{editGender === item.key ? 'selected' : ''}}"
            data-key="{{item.key}}"
            bindtap="onGenderSelect"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="profile-field">
        <text class="field-label">手机号</text>
        <input
          class="field-input"
          type="number"
          placeholder="选填，便于运营联系"
          placeholder-style="color: #A8A39B;"
          value="{{editPhone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>

      <view class="profile-btns">
        <view class="btn-ghost profile-btn" bindtap="onCloseProfileSheet">取消</view>
        <view class="btn-primary profile-btn" bindtap="onSaveProfile">保存</view>
      </view>
      <view class="safe-bottom"></view>
    </view>
  </view>

  <!-- Purchase sheet -->
  <view wx:if="{{showPurchaseSheet}}">
    <view class="sheet-mask" bindtap="onClosePurchaseSheet"></view>
    <view class="sheet purchase-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="sheet-title serif">{{isRenew ? '续费会员' : '开通会员'}}</text>
      <text class="purchase-subtitle">联系运营完成{{isRenew ? '续费' : '开通'}}，每年 ¥365</text>

      <view class="steps-list">
        <view wx:for="{{purchaseSteps}}" wx:key="num" class="step-item">
          <view class="step-num-wrap">
            <text class="step-num serif">{{item.num}}</text>
          </view>
          <view class="step-content">
            <text class="step-title">{{item.title}}</text>
            <text class="step-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="admin-card" wx:if="{{adminContact}}">
        <view class="admin-row">
          <text class="admin-label">联系人</text>
          <text class="admin-value">{{adminContact.name}}</text>
        </view>
        <view class="admin-row">
          <text class="admin-label">微信号</text>
          <view class="admin-wechat-row">
            <text class="admin-value mono">{{adminContact.wechat}}</text>
            <text class="copy-btn" bindtap="onCopyWechat">复制</text>
          </view>
        </view>
        <view class="admin-row">
          <text class="admin-label">在线时间</text>
          <text class="admin-value">{{adminContact.hours}}</text>
        </view>
        <text class="admin-note">{{adminContact.note}}</text>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </view>

  <!-- 设置弹层：协议链接 + 退出登录 -->
  <view wx:if="{{showSettingsSheet}}">
    <view class="sheet-mask" bindtap="onCloseSettings"></view>
    <view class="sheet settings-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="sheet-title serif">设置</text>
      <view class="section-card settings-links">
        <view class="settings-row" bindtap="onOpenAgreement">
          <text class="settings-row-text">用户服务协议</text>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
        <view class="settings-row no-border" bindtap="onOpenPrivacy">
          <text class="settings-row-text">隐私协议</text>
          <view class="settings-row-arrow ic-chevron"></view>
        </view>
      </view>
      <view class="settings-logout" bindtap="onLogout">退出登录</view>
      <view class="safe-bottom"></view>
    </view>
  </view>
</view>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
