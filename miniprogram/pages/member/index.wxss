.page-wrap {
  min-height: 100vh;
}

.page-header {
  padding: 16rpx 32rpx 12rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

.page-scroll {
  height: calc(100vh - 100rpx);
  padding: 0 24rpx;
}

/* ===== Identity cards ===== */
.identity-card {
  border-radius: 16px;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.guest-card {
  background: #F5EFE2;
  border: 1px dashed rgba(126, 102, 64, 0.3);
}

.authed-card {
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
}

.member-card {
  background: linear-gradient(135deg, #FFFBED 0%, #FFF3CC 50%, #FFFCF5 100%);
  border: 1px solid #B89968;
  box-shadow: 0 8rpx 30rpx rgba(184, 153, 104, 0.2);
}

/* Guest avatar */
.guest-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2px dashed #D6D0C2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guest-question {
  font-size: 44rpx;
  color: #D6D0C2;
}

.identity-info {
  flex: 1;
  min-width: 0;
  padding-right: 110rpx;
}

.identity-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.identity-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2A2723;
}

.member-name {
  color: #9A7E4F;
}

/* Identity badges */
.identity-label-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 2px 10px;
  border-radius: 20px;
}

.guest-badge {
  color: #7A746A;
  background: #EFE7D4;
}

.authed-badge {
  color: #fff;
  background: #4577A4;
}

.member-badge {
  color: #9A7E4F;
  background: #F4ECD9;
  border: 1px solid #B89968;
}

.identity-phone {
  font-size: 24rpx;
  color: #A8A39B;
  display: block;
}

.identity-hint {
  font-size: 24rpx;
  color: #7A746A;
  display: block;
}

.member-until-text {
  font-size: 22rpx;
  color: #9A7E4F;
  display: block;
  margin-top: 4rpx;
}

/* ===== Seal (all 3 states) ===== */
.id-seal {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%) rotate(4deg);
  width: 100rpx;
  height: 100rpx;
  border-radius: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.id-seal-text {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  line-height: 1.3;
  text-align: center;
  display: block;
}

.guest-seal {
  border: 1.5px solid rgba(168, 163, 155, 0.5);
  background: rgba(168, 163, 155, 0.06);
}

.guest-seal .id-seal-text {
  color: rgba(122, 116, 106, 0.8);
}

.authed-seal {
  border: 1.5px solid rgba(69, 119, 164, 0.4);
  background: rgba(69, 119, 164, 0.05);
}

.authed-seal .id-seal-text {
  color: rgba(69, 119, 164, 0.75);
}

.member-seal {
  border: 1.5px solid rgba(182, 69, 47, 0.5);
  background: rgba(182, 69, 47, 0.05);
  transform: translateY(-50%) rotate(-5deg);
}

.member-seal-line {
  font-size: 20rpx;
  color: rgba(182, 69, 47, 0.75);
  letter-spacing: 2rpx;
  line-height: 1.4;
  display: block;
  text-align: center;
}

/* ===== Real photo avatar ===== */
.avatar-real {
  border-radius: 50%;
  width: 100rpx;
  height: 100rpx;
}

/* Clickable avatar wrapper */
.avatar-wrap-click {
  position: relative;
  flex-shrink: 0;
}

.avatar-edit-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #A8A39B;
  border: 2rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #fff;
}

/* Member avatar badge */
.member-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.member-avatar-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F4ECD9, #C9A14A);
  border: 2px solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #9A7E4F;
  font-weight: 700;
}

/* ===== Auth section (guest) ===== */
.auth-section {
  margin-bottom: 28rpx;
}

.auth-btn {
  width: 100%;
  font-size: 30rpx;
  padding: 28rpx;
  border-radius: 14px;
  letter-spacing: 3rpx;
}

.auth-btn::after {
  border: none;
}

.auth-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #A8A39B;
  margin-top: 12rpx;
}

/* ===== Member join card (authed state) ===== */
.member-join-card {
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  border-radius: 14px;
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.member-join-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.member-join-title {
  font-size: 30rpx;
  color: #2A2723;
  letter-spacing: 2rpx;
}

.member-join-price {
  font-size: 22rpx;
  color: #A8A39B;
}

.member-join-desc {
  display: block;
  font-size: 24rpx;
  color: #7A746A;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.member-join-btn {
  width: 100%;
  padding: 22rpx;
  border-radius: 10px;
  font-size: 28rpx;
  letter-spacing: 3rpx;
}

/* ===== Section header row ===== */
.section-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

/* Override global section-label for serif + spacing */
.section-label {
  font-size: 26rpx;
  color: #7A746A;
  letter-spacing: 3rpx;
  display: block;
}

.section-action {
  font-size: 24rpx;
  color: #4577A4;
}

/* ===== Section cards ===== */
.section-card {
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  border-radius: 14px;
  padding: 0 28rpx;
  margin-bottom: 4rpx;
}

/* ===== Info rows ===== */
.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1px solid rgba(126, 102, 64, 0.07);
}

.info-row.no-border {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #A8A39B;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #2A2723;
  text-align: right;
}

.info-value.muted {
  color: #A8A39B;
}

.info-value.empty {
  color: #D6D0C2;
}

/* ===== Stats 2×2 grid ===== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.stat-box {
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.14);
  border-radius: 14rpx;
  padding: 24rpx 26rpx;
}

.stat-box-label {
  font-size: 22rpx;
  color: #A8A39B;
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 10rpx;
}

.stat-box-value-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 6rpx;
}

.stat-box-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2723;
}

.stat-box-unit {
  font-size: 22rpx;
  color: #7A746A;
}

/* ===== Days renew card (member) ===== */
.days-renew-card {
  background: linear-gradient(135deg, #FFFBED, #FFF5D6);
  border: 1px solid #B89968;
  border-radius: 14px;
  padding: 24rpx 28rpx;
  margin-bottom: 4rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.days-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.days-num-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.days-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #9A7E4F;
}

.days-unit {
  font-size: 26rpx;
  color: #9A7E4F;
  margin-left: 4rpx;
}

.days-desc-label {
  font-size: 22rpx;
  color: #B89968;
  display: block;
}

.renew-btn {
  padding: 14rpx 28rpx;
  background: rgba(182, 69, 47, 0.07);
  border: 1px solid rgba(182, 69, 47, 0.2);
  border-radius: 8px;
  font-size: 24rpx;
  color: #B6452F;
}

/* ===== Benefits list ===== */
.benefits-card {
  padding: 0 28rpx;
}

.benefit-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(126, 102, 64, 0.07);
}

.benefit-item:last-child {
  border-bottom: none;
}

.benefit-item.dimmed {
  opacity: 0.5;
}

.benefit-diamond {
  font-size: 24rpx;
  color: #D6D0C2;
  flex-shrink: 0;
  width: 30rpx;
  text-align: center;
}

.benefit-diamond.active {
  color: #C9A14A;
}

.benefit-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.benefit-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2723;
  display: block;
}

.benefit-desc {
  font-size: 22rpx;
  color: #A8A39B;
  display: block;
}

.benefit-check {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* ===== Order card ===== */
.order-header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0 16rpx;
  border-bottom: 1px solid rgba(126, 102, 64, 0.07);
}

.order-id-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-id-label {
  font-size: 22rpx;
  color: #A8A39B;
}

.order-id-value {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: #4A453E;
}

.order-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4px;
}

.order-status.paid {
  color: #5B8F6C;
  background: rgba(91, 143, 108, 0.1);
}

.order-meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 18rpx 0 8rpx;
}

.order-meta-cell {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-meta-cell.order-meta-full {
  grid-column: 1 / -1;
}

.order-meta-key {
  font-size: 22rpx;
  color: #A8A39B;
  display: block;
}

.order-meta-val {
  font-size: 24rpx;
  color: #2A2723;
  display: block;
}

/* ===== Profile sheet ===== */
.profile-sheet {
  padding: 24rpx 32rpx 20rpx;
}

.sheet-handle {
  width: 80rpx;
  height: 6rpx;
  background: rgba(126, 102, 64, 0.2);
  border-radius: 3rpx;
  margin: 0 auto 32rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2A2723;
  display: block;
  margin-bottom: 32rpx;
  letter-spacing: 1px;
}

.avatar-picker-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 0 20rpx;
  background: transparent;
  border: none;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
  line-height: normal;
  border-radius: 0;
}

.avatar-picker-row::after { border: none; }

.avatar-picker-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-picker-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-picker-initial {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-picker-label {
  font-size: 28rpx;
  color: #2A2723;
  margin-left: 24rpx;
  flex: 1;
}

.avatar-picker-arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.profile-divider {
  height: 1rpx;
  background: #EFE7D4;
  margin: 0 0 8rpx;
}

.profile-field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #A8A39B;
  margin-bottom: 10rpx;
  letter-spacing: 0.5px;
}

.field-input {
  width: 100%;
  box-sizing: border-box;
  background: #F3ECDB;
  border: 2rpx solid #C9B892;
  border-radius: 10px;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #2A2723;
}

.profile-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 12rpx;
}

.profile-btn {
  flex: 1;
  font-size: 28rpx;
}

/* ===== Purchase sheet ===== */
.purchase-sheet {
  padding: 24rpx 32rpx 20rpx;
  max-height: 85vh;
}

.purchase-subtitle {
  display: block;
  font-size: 26rpx;
  color: #7A746A;
  margin-bottom: 32rpx;
}

.steps-list {
  margin-bottom: 28rpx;
}

.step-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.step-num-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(182, 69, 47, 0.08);
  border: 1px solid rgba(182, 69, 47, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-num {
  font-size: 22rpx;
  color: #B6452F;
  font-weight: 600;
}

.step-content {
  flex: 1;
  padding-top: 6rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2723;
  margin-bottom: 4rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: #7A746A;
}

/* ===== Admin card ===== */
.admin-card {
  background: #F5EFE2;
  border-radius: 12px;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.admin-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1px solid rgba(126, 102, 64, 0.08);
}

.admin-row:last-of-type {
  border-bottom: none;
}

.admin-label {
  font-size: 24rpx;
  color: #A8A39B;
}

.admin-value {
  font-size: 24rpx;
  color: #2A2723;
}

.admin-value.mono {
  font-family: monospace;
}

.admin-wechat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #4577A4;
  background: rgba(69, 119, 164, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 6px;
}

.admin-note {
  display: block;
  font-size: 22rpx;
  color: #A8A39B;
  margin-top: 14rpx;
  line-height: 1.6;
}

/* ===== Bottom padding ===== */
.bottom-pad {
  height: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* v2.3 设置 · 退出登录 */
.logout-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.logout-text {
  font-size: 28rpx;
  color: #B3574A;
}

.logout-arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}
