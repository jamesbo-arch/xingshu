<view class="page-wrap paper-bg">
  <!-- Status bar spacer -->
  <view style="height: {{statusBarHeight}}px; background: #FBF7EE;"></view>
  <!-- Custom nav bar（发布按钮下移到底部固定栏，避免右上角被微信胶囊遮挡） -->
  <view class="compose-nav">
    <view class="nav-back" bindtap="onBack">
      <view class="nav-back-icon ic-back"></view>
    </view>
    <text class="nav-title serif">{{isEditing ? '编辑日记' : '新建日记'}}</text>
    <view class="nav-back"></view>
  </view>

  <scroll-view class="compose-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- Title input -->
    <view class="title-wrap">
      <input
        class="title-input serif"
        placeholder="日记标题"
        placeholder-style="color: #D6D0C2; font-size: 44rpx; font-family: 'Songti SC','STSong','SimSun',serif;"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="{{maxTitle}}"
      />
      <text class="title-counter">{{title.length}}/{{maxTitle}}</text>
    </view>

    <view class="compose-divider"></view>

    <!-- Content editor（富文本：选中文字浮出底部工具条设置颜色/粗斜体/下划线） -->
    <view class="content-wrap">
      <editor
        id="content-editor"
        class="content-input"
        placeholder="写下今日所思所感…"
        bindready="onEditorReady"
        bindinput="onEditorInput"
        bindstatuschange="onEditorStatus"
        bindfocus="onEditorFocus"
        bindblur="onEditorBlur"
      ></editor>
      <text class="content-counter {{content.length > maxContent ? 'counter-over' : ''}}">{{content.length}}/{{maxContent}}</text>
    </view>

    <!-- Images section -->
    <view class="section-block">
      <text class="section-label">配图 {{images.length ? images.length + '/' + maxImages : ''}}</text>
      <view class="image-grid">
        <view wx:for="{{images}}" wx:key="*this" class="image-cell">
          <image
            class="image-thumb"
            src="{{item}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage"
          />
          <view class="image-remove" data-index="{{index}}" catchtap="onRemoveImage">
            <text>×</text>
          </view>
        </view>
        <view wx:if="{{images.length < maxImages}}" class="image-add" bindtap="onAddImage">
          <text class="image-add-icon">+</text>
          <text class="image-add-text">添加</text>
        </view>
      </view>
    </view>

    <!-- Tags section -->
    <view class="section-block">
      <text class="section-label">主题标签</text>
      <view class="tags-wrap">
        <text
          wx:for="{{selectedTags}}"
          wx:key="*this"
          class="seal-tag selected removable"
          data-tag="{{item}}"
          bindtap="removeTag"
        >{{item}} ×</text>
        <view class="add-tag-btn" bindtap="onOpenTagPicker">
          <text class="add-tag-icon">+</text>
          <text class="add-tag-text">添加</text>
        </view>
      </view>
    </view>

    <!-- Permission selector -->
    <view class="section-block">
      <text class="section-label">可见范围</text>
      <view class="perm-options">
        <view
          wx:for="{{permOptions}}"
          wx:key="key"
          class="perm-option {{permission === item.key ? 'selected' : ''}} {{item.key === 'member' && !isMember ? 'perm-locked' : ''}}"
          data-key="{{item.key}}"
          bindtap="setPermission"
        >
          <view class="perm-option-icon {{item.ic}}"></view>
          <view class="perm-option-info">
            <text class="perm-option-label">{{item.label}}</text>
            <text class="perm-option-desc">{{item.key === 'member' && !isMember ? '开通会员后可发布' : item.desc}}</text>
          </view>
          <view wx:if="{{item.key === 'member' && !isMember}}" class="perm-lock-tag">会员专属</view>
          <view wx:elif="{{permission === item.key}}" class="perm-check ic-check-g"></view>
        </view>
      </view>
    </view>

    <view class="compose-bottom-pad"></view>
  </scroll-view>

  <!-- 富文本工具条：选中正文文字时出现（catch:touchend 防编辑器失焦丢选区），跟随键盘高度 -->
  <view
    wx:if="{{showFormatBar}}"
    class="format-bar"
    style="bottom: {{kbHeight > 0 ? kbHeight + 'px' : 'calc(130rpx + env(safe-area-inset-bottom))'}}"
  >
    <view
      wx:for="{{formatColors}}"
      wx:key="value"
      class="fmt-color {{activeColor === item.value ? 'fmt-color-on' : ''}}"
      style="background: {{item.value}}"
      data-name="color"
      data-value="{{item.value}}"
      catch:touchend="onFormat"
    ></view>
    <view class="fmt-divider"></view>
    <view class="fmt-btn fmt-b {{fmtBold ? 'fmt-on' : ''}}" data-name="bold" catch:touchend="onFormat">B</view>
    <view class="fmt-btn fmt-i {{fmtItalic ? 'fmt-on' : ''}}" data-name="italic" catch:touchend="onFormat">I</view>
    <view class="fmt-btn fmt-u {{fmtUnderline ? 'fmt-on' : ''}}" data-name="underline" catch:touchend="onFormat">U</view>
  </view>

  <!-- Bottom action bar（固定：取消 / 发布） -->
  <view class="compose-actionbar">
    <view class="action-cancel" bindtap="onCancel">取消</view>
    <view
      class="action-publish {{title && content ? '' : 'disabled'}}"
      bindtap="onPublish"
    >{{isEditing ? '保存' : '发布'}}</view>
  </view>

  <!-- Tag picker sheet -->
  <view wx:if="{{showTagPicker}}">
    <view class="sheet-mask" bindtap="onCloseTagPicker"></view>
    <view class="sheet tag-picker-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="tag-picker-title serif">选择标签</text>
      <view class="tag-picker-grid">
        <text
          wx:for="{{allTags}}"
          wx:key="*this"
          class="seal-tag {{pickerTagSet[item] ? 'selected' : ''}}"
          data-tag="{{item}}"
          bindtap="togglePickerTag"
        >{{item}}</text>
      </view>
      <view class="tag-picker-btns">
        <view class="btn-ghost tag-picker-btn" bindtap="onClearPickerTags">清除</view>
        <view class="btn-primary tag-picker-btn" bindtap="onConfirmTags">确认 ({{pickerSelectedTags.length}})</view>
      </view>
    </view>
  </view>
</view>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
