.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Custom nav */
.compose-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #FBF7EE;
  border-bottom: 1px solid rgba(126, 102, 64, 0.08);
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #2A2723;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 1px;
}

.nav-publish {
  padding: 12rpx 28rpx;
  background: #2A2723;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #FBF7EE;
  font-weight: 600;
}

.nav-publish.disabled {
  background: #D6D0C2;
  color: #fff;
}

/* Scroll */
.compose-scroll {
  flex: 1;
  height: calc(100vh - 110rpx);
  padding: 0 32rpx;
}

/* Title */
.title-wrap {
  padding: 32rpx 0 16rpx;
  position: relative;
}

.title-input {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2723;
  width: 100%;
  line-height: 1.4;
}

.title-counter {
  font-size: 22rpx;
  color: #D6D0C2;
  display: block;
  text-align: right;
  margin-top: 8rpx;
}

.compose-divider {
  height: 1px;
  background: rgba(126, 102, 64, 0.1);
  margin: 8rpx 0 20rpx;
}

/* Content */
.content-wrap {
  margin-bottom: 32rpx;
  position: relative;
}

.content-input {
  width: 100%;
  min-height: 480rpx;
  font-size: 30rpx;
  color: #2A2723;
  line-height: 1.8;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.content-counter {
  font-size: 22rpx;
  color: #D6D0C2;
  display: block;
  text-align: right;
  margin-top: 8rpx;
}

/* Section blocks */
.section-block {
  margin-bottom: 36rpx;
}

/* Tags wrap */
.tags-wrap {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.removable {
  cursor: pointer;
}

.add-tag-btn {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 16rpx;
  border: 1px dashed rgba(126, 102, 64, 0.3);
  border-radius: 6px;
}

.add-tag-icon {
  font-size: 28rpx;
  color: #A8A39B;
}

.add-tag-text {
  font-size: 24rpx;
  color: #A8A39B;
}

/* Permission options */
.perm-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.perm-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: #F5EFE2;
  border-radius: 12px;
  border: 1.5px solid transparent;
}

.perm-option.selected {
  background: #FFFCF5;
  border-color: rgba(126, 102, 64, 0.25);
}

.perm-option-icon {
  font-size: 30rpx;
  color: #A8A39B;
  width: 36rpx;
  text-align: center;
}

.perm-option-info {
  flex: 1;
}

.perm-option-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2723;
}

.perm-option-desc {
  display: block;
  font-size: 24rpx;
  color: #A8A39B;
}

.perm-check {
  font-size: 28rpx;
  color: #5B8F6C;
  font-weight: 700;
}

.compose-bottom-pad {
  height: 80rpx;
}

/* Tag picker sheet */
.tag-picker-sheet {
  padding: 24rpx 32rpx 20rpx;
  max-height: 75vh;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #D6D0C2;
  border-radius: 4px;
  margin: 0 auto 24rpx;
}

.tag-picker-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2723;
  margin-bottom: 24rpx;
  letter-spacing: 1px;
}

.tag-picker-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 28rpx;
}

.tag-picker-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.tag-picker-btn {
  flex: 1;
  font-size: 28rpx;
}

/* Image grid */
.image-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8px;
  background: rgba(126, 102, 64, 0.06);
}

.image-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(60, 50, 35, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-remove text {
  color: #FBF7EE;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 1px dashed rgba(126, 102, 64, 0.3);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.image-add-icon {
  font-size: 48rpx;
  color: #A8A39B;
  line-height: 1;
}

.image-add-text {
  font-size: 24rpx;
  color: #A8A39B;
}
