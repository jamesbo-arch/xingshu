.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FBF7EE;
}

.page-header {
  padding: 16rpx 32rpx 20rpx;
  flex-shrink: 0;
}

.page-title {
  font-size: 56rpx;
  letter-spacing: 8rpx;
  color: #2A2723;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: #A8A39B;
  margin-top: 4rpx;
  display: block;
}

.serif {
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.act-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
  box-sizing: border-box;
  width: 100%;
}

.act-section-title {
  font-size: 30rpx;
  letter-spacing: 6rpx;
  color: #2A2723;
  margin: 16rpx 0 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.act-section-title::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: rgba(126, 102, 64, 0.18);
}

.activity-card {
  background: #FFFCF5;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(126, 102, 64, 0.16);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 28rpx;
}

.act-cover {
  position: relative;
  height: 300rpx;
  background: #EFE7D4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.act-cover-img {
  width: 100%;
  height: 100%;
}

.act-cover-char {
  font-size: 128rpx;
  letter-spacing: 16rpx;
  color: rgba(126, 102, 64, 0.45);
}

.act-cover-seal {
  position: absolute;
  left: 24rpx;
  bottom: 20rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #B6452F;
  border: 2rpx solid #B6452F;
  border-radius: 4rpx;
  padding: 4rpx 8rpx;
  opacity: 0.75;
}

.act-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  letter-spacing: 2rpx;
}

.act-badge-open { color: #fff; background: #B6452F; }
.act-badge-full { color: #7A746A; background: rgba(239, 231, 212, 0.94); }
.act-badge-past { color: #FBF7EE; background: rgba(42, 39, 35, 0.72); }

.act-card-body {
  padding: 24rpx 28rpx 28rpx;
}

.act-card-title {
  font-size: 32rpx;
  line-height: 1.45;
  color: #2A2723;
  display: block;
  margin-bottom: 16rpx;
}

.act-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 25rpx;
  color: #7A746A;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.act-meta-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.act-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.act-progress {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: #EFE7D4;
  overflow: hidden;
}

.act-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #C2563F, #B6452F);
}

.act-count {
  font-size: 22rpx;
  color: #A8A39B;
  flex-shrink: 0;
}

.act-count-past {
  font-size: 22rpx;
  color: #A8A39B;
}

.act-empty {
  text-align: center;
  padding: 120rpx 48rpx;
}

.act-empty-icon {
  font-size: 112rpx;
  color: #D6D0C2;
  letter-spacing: 12rpx;
  display: block;
  margin-bottom: 24rpx;
}

.act-empty-title {
  font-size: 30rpx;
  color: #7A746A;
  display: block;
  margin-bottom: 12rpx;
}

.act-empty-hint {
  font-size: 26rpx;
  color: #A8A39B;
  display: block;
}

.act-bottom-pad {
  height: 200rpx;
}
