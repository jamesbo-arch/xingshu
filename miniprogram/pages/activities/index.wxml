<view class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px; background: #FBF7EE;"></view>
  <view class="page-header">
    <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="page-title serif">醒書活動</text><kefu-fab /></view>
  </view>

  <!-- 双页签：活动分享（默认）/ 全部活动 -->
  <view class="act-tabs">
    <view class="act-tab serif {{tab === 'share' ? 'act-tab-on' : ''}}" data-tab="share" bindtap="onTabTap">活动分享</view>
    <view class="act-tab serif {{tab === 'all' ? 'act-tab-on' : ''}}" data-tab="all" bindtap="onTabTap">全部活动</view>
  </view>

  <!-- ── 页签一：活动分享 双列瀑布流 ── -->
  <scroll-view wx:if="{{tab === 'share'}}" class="act-scroll" scroll-y enhanced show-scrollbar="{{false}}"
    bindscrolltolower="onFeedMore" lower-threshold="200"
    refresher-enabled refresher-background="#FBF7EE" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view wx:if="{{feedLoaded && !colL.length && !colR.length}}" class="act-empty">
      <text class="act-empty-icon serif">享</text>
      <text class="act-empty-title">还没有现场分享</text>
      <text class="act-empty-hint act-empty-link" bindtap="onGoAll">去看看近期活动 →</text>
    </view>
    <view class="feed-cols">
      <view class="feed-col">
        <block wx:for="{{colL}}" wx:key="id">
          <view class="m-card" data-aid="{{item.activityId}}" bindtap="onOpenPost">
            <!-- 视频卡：未授权渲染首帧占位（点击拉登录），授权后才渲染 video 流式播放 -->
            <view wx:if="{{item.video && isGuest}}" class="m-cover m-video-wrap m-video-locked">
              <image wx:if="{{item.videoPoster}}" class="m-video-poster" src="{{item.videoPoster}}" mode="aspectFill" lazy-load />
              <view class="m-video-mask">
                <view class="m-video-play"></view>
                <text class="m-video-lock-tip">登录后观看视频</text>
              </view>
            </view>
            <view wx:elif="{{item.video}}" class="m-cover m-video-wrap" catchtap="noop">
              <video class="m-video" src="{{item.video}}" poster="{{item.videoPoster}}" controls object-fit="contain" />
            </view>
            <view wx:elif="{{item.image}}" class="m-cover" style="height: {{item.imgH}}rpx;">
              <image class="m-img" src="{{item.image}}" mode="aspectFill" lazy-load />
              <text wx:if="{{item.imgCount > 1}}" class="m-imgcount">{{item.imgCount}} 图</text>
            </view>
            <text wx:if="{{item.text}}" class="m-text {{(item.image || item.video) ? '' : 'm-text-solo'}}">{{item.text}}</text>
            <view class="m-actline"><text class="m-act">{{item.actLabel}}</text><text wx:if="{{item.actDate}}" class="m-actdate">{{item.actDate}}</text></view>
            <view class="m-foot">
              <image wx:if="{{item.avatarUrl}}" class="m-ava-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <view wx:else class="m-ava" style="background-color: {{item.avatarColor}};"><text>{{item.initial}}</text></view>
              <text class="m-nick">{{item.nickname}}</text>
              <view class="m-like {{item.isLiked ? 'm-like-on' : ''}}" data-id="{{item.id}}" catchtap="onLikePost">
                <view class="hicon"></view><text wx:if="{{item.likeCount}}" class="m-like-n">{{item.likeCount}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="feed-col">
        <block wx:for="{{colR}}" wx:key="id">
          <view class="m-card" data-aid="{{item.activityId}}" bindtap="onOpenPost">
            <!-- 视频卡：未授权渲染首帧占位（点击拉登录），授权后才渲染 video 流式播放 -->
            <view wx:if="{{item.video && isGuest}}" class="m-cover m-video-wrap m-video-locked">
              <image wx:if="{{item.videoPoster}}" class="m-video-poster" src="{{item.videoPoster}}" mode="aspectFill" lazy-load />
              <view class="m-video-mask">
                <view class="m-video-play"></view>
                <text class="m-video-lock-tip">登录后观看视频</text>
              </view>
            </view>
            <view wx:elif="{{item.video}}" class="m-cover m-video-wrap" catchtap="noop">
              <video class="m-video" src="{{item.video}}" poster="{{item.videoPoster}}" controls object-fit="contain" />
            </view>
            <view wx:elif="{{item.image}}" class="m-cover" style="height: {{item.imgH}}rpx;">
              <image class="m-img" src="{{item.image}}" mode="aspectFill" lazy-load />
              <text wx:if="{{item.imgCount > 1}}" class="m-imgcount">{{item.imgCount}} 图</text>
            </view>
            <text wx:if="{{item.text}}" class="m-text {{(item.image || item.video) ? '' : 'm-text-solo'}}">{{item.text}}</text>
            <view class="m-actline"><text class="m-act">{{item.actLabel}}</text><text wx:if="{{item.actDate}}" class="m-actdate">{{item.actDate}}</text></view>
            <view class="m-foot">
              <image wx:if="{{item.avatarUrl}}" class="m-ava-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <view wx:else class="m-ava" style="background-color: {{item.avatarColor}};"><text>{{item.initial}}</text></view>
              <text class="m-nick">{{item.nickname}}</text>
              <view class="m-like {{item.isLiked ? 'm-like-on' : ''}}" data-id="{{item.id}}" catchtap="onLikePost">
                <view class="hicon"></view><text wx:if="{{item.likeCount}}" class="m-like-n">{{item.likeCount}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
    <view class="act-bottom-pad {{actBannerCount ? 'pad-banner' : ''}}"></view>
  </scroll-view>

  <!-- ── 页签二：全部活动 简洁列表（时间倒序） ── -->
  <scroll-view wx:else class="act-scroll" scroll-y enhanced show-scrollbar="{{false}}"
    refresher-enabled refresher-background="#FBF7EE" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <scroll-view wx:if="{{types.length}}" class="type-chips" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="type-chip {{activeTypeId === 0 ? 'chip-on' : ''}}" data-id="0" bindtap="onTypeTap">全部</view>
      <view
        wx:for="{{types}}"
        wx:key="id"
        class="type-chip {{activeTypeId === item.id ? 'chip-on' : ''}}"
        data-id="{{item.id}}"
        bindtap="onTypeTap"
      >{{item.name}}</view>
    </scroll-view>

    <view wx:if="{{allLoaded && !actItems.length}}" class="act-empty">
      <text class="act-empty-icon serif">期</text>
      <text class="act-empty-title">活动筹备中</text>
      <text class="act-empty-hint">敬请期待</text>
    </view>

    <block wx:for="{{actItems}}" wx:key="key">
      <view wx:if="{{item.kind === 'month'}}" class="act-month serif">{{item.label}}</view>
      <view wx:else class="act-row {{item.st === 'done' ? 'act-row-past' : ''}}" data-id="{{item.id}}" bindtap="onOpen">
        <view class="act-tico {{item.tcls}}">
          <view class="tico tico-{{item.tico}}"></view>
        </view>
        <view class="act-rmain">
          <text class="act-rtitle">{{item.title}}</text>
          <view class="act-rmeta">
            <text>{{item.timeText}} · {{item.place}}{{item.full ? ' · 名额已满' : ''}}</text>
            <text class="act-rtype {{item.tcls}}">{{item.typeName}}</text>
          </view>
        </view>
        <text class="act-st act-st-{{item.st}}">{{item.stLabel}}</text>
      </view>
    </block>
    <view class="act-bottom-pad"></view>
  </scroll-view>

  <!-- 近期活动预告轮播（共享组件）：仅分享页签展示，固定于 tab-bar 之上 -->
  <view class="act-banner-bar" hidden="{{tab !== 'share' || !actBannerCount}}">
    <act-banner id="actBanner" bind:change="onActBannerChange" bind:open="onActBannerOpen"></act-banner>
  </view>

  <!-- 分享页签 FAB：直达发布分享（参照广场写故事入口） -->
  <view wx:if="{{tab === 'share'}}" class="fab {{actBannerCount ? 'fab-raised' : ''}}" bindtap="onShareFab">
    <view class="fab-icon ic-camera-w"></view>
  </view>

  <!-- 发布分享弹层：场次选择（已报名且已开始，按时间倒序）+ 文字 + 照片 -->
  <view wx:if="{{showPostSheet}}">
    <view class="sheet-mask {{_postShow ? 'mask-show' : ''}}" bindtap="onClosePostSheet"></view>
    <view class="sheet post-sheet {{_postShow ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-handle"></view>
      <text class="post-sheet-title serif">分享现场</text>
      <text class="post-label">活动场次</text>
      <picker range="{{postableTitles}}" value="{{postActIndex}}" bindchange="onPostActChange">
        <view class="post-act-picker">
          <text class="post-act-name">{{postableTitles[postActIndex]}}</text>
          <text class="post-act-arrow">▾</text>
        </view>
      </picker>
      <textarea
        class="post-textarea"
        placeholder="记录此刻的所见所感…"
        placeholder-style="color: #A8A39B;"
        maxlength="1000"
        value="{{postContent}}"
        bindinput="onPostInput"
        show-confirm-bar="{{false}}"
      />
      <view class="post-pick-grid">
        <view wx:for="{{postImages}}" wx:key="*this" class="post-pick-cell">
          <image class="post-pick-thumb" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewPickImage"/>
          <view class="post-pick-remove" data-index="{{index}}" catchtap="onRemovePostImage"><text>×</text></view>
        </view>
        <!-- 已选视频：预览格（与照片互斥） -->
        <view wx:if="{{postVideo}}" class="post-pick-cell post-pick-video">
          <video class="post-pick-thumb" src="{{postVideo}}" object-fit="cover" controls="{{false}}" muted autoplay loop/>
          <view class="post-pick-remove" catchtap="onRemovePostVideo"><text>×</text></view>
        </view>
        <view wx:if="{{!postVideo && postImages.length < 9}}" class="post-pick-add" bindtap="onAddPostImage">
          <text class="post-pick-add-icon">+</text>
          <text class="post-pick-add-text">{{postImages.length ? '照片' : '照片/视频'}}</text>
        </view>
      </view>
      <view class="post-submit" bindtap="onSubmitPost">发布</view>
    </view>
  </view>

  <!-- v2.3 微信登录弹窗：游客点 FAB 时拉起，登录后自动续做 -->
  <login-sheet
    visible="{{showLoginSheet}}"
    subtitle="登录后即可分享活动现场，和同路人分享此刻。"
    bind:close="onLoginClose"
    bind:success="onLoginSuccess"
  ></login-sheet>
</view>

<!-- 冷启动品牌蒙布（v2.0 起本页为启动首页；扫码/转发直达详情时改由详情页认领） -->
<splash-cover visible="{{showSplash}}" bind:enter="onSplashEnter"></splash-cover>
