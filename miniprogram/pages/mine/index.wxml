<view class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="page-header">
    <view class="header-top">
      <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="page-title serif">我的故事</text><kefu-fab /></view>
    </view>
    <view class="search-row">
      <view class="search-bar">
        <view class="search-icon ic-search"></view>
        <input
          class="search-input"
          placeholder="搜索我的故事"
          placeholder-style="color: #A8A39B; font-size: 28rpx;"
          value="{{search}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
        <view wx:if="{{search}}" class="search-clear ic-close" bindtap="onSearchClear"></view>
      </view>
      <view class="filter-btn {{filtersActive ? 'filter-active' : ''}}" bindtap="onOpenFilter">
        <view class="filter-icon {{filtersActive ? 'ic-filter-w' : 'ic-filter'}}"></view>
        <view wx:if="{{filtersActive}}" class="filter-dot"></view>
      </view>
    </view>
  </view>

  <!-- Story list -->
  <scroll-view class="story-list" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onReachBottom" lower-threshold="150" refresher-enabled refresher-background="#FBF7EE" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view wx:if="{{stories.length === 0}}" class="empty-state">
      <view class="empty-icon ic-pen"></view>
      <text class="empty-text">还没有故事</text>
      <text class="empty-hint">点击右下角按钮开始写作</text>
    </view>
    <story-card
      wx:for="{{stories}}"
      wx:key="id"
      story="{{item}}"
      show-actions="{{true}}"
      owner-stats="{{true}}"
      bind:open="onCardOpen"
      bind:edit="onCardEdit"
      bind:delete="onCardDelete"
      bind:viewread="onViewRead"
      bind:viewlike="onViewLike"
      bind:viewfav="onViewFav"
      bind:viewcomment="onViewComment"
    ></story-card>
    <view class="list-bottom-pad"></view>
  </scroll-view>

  <!-- FAB -->
  <view class="fab" bindtap="onFabTap">
    <view class="fab-icon ic-pen-w"></view>
  </view>

  <!-- Filter sheet -->
  <filter-sheet
    visible="{{showFilterSheet}}"
    filters="{{filters}}"
    all-tags="{{allTags}}"
    bind:close="onCloseFilter"
    bind:apply="onApplyFilter"
  ></filter-sheet>

  <!-- v2.3 微信登录弹窗：guest 点卡片/互动时拉起，登录后自动续做（与广场页一致） -->
  <login-sheet
    visible="{{showLoginSheet}}"
    subtitle="登录后即可查看和管理你的故事。"
    bind:close="onLoginClose"
    bind:success="onLoginSuccess"
  ></login-sheet>

  <!-- 作者数据视角：阅读/点赞/收藏/评论人员清单 -->
  <audience-sheet
    visible="{{audienceVisible}}"
    title="{{audienceTitle}}"
    type="{{audienceType}}"
    story-id="{{audienceStoryId}}"
    bind:close="onAudienceClose"
  ></audience-sheet>
</view>
