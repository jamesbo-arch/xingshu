.page-wrap {
  min-height: 100vh;
  position: relative;
}

.content-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx;
}

/* Title */
.detail-title-wrap {
  padding-top: 36rpx;
  margin-bottom: 28rpx;
}

.detail-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2A2723;
  line-height: 1.4;
}

/* Author row */
.author-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.member-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F4ECD9, #C9A14A);
  border: 1px solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-badge-text {
  font-size: 14rpx;
  color: #9A7E4F;
  font-weight: 700;
  line-height: 1;
}

.author-meta {
  flex: 1;
}

.author-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2723;
}

.author-time {
  display: block;
  font-size: 22rpx;
  color: #A8A39B;
}

/* Tags */
.detail-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 32rpx;
}

/* Content */
.detail-content {
  margin-bottom: 48rpx;
}

.content-text {
  font-size: 30rpx;
  color: #2A2723;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;      /* 长网址/英文串强制断行，避免顶出右边界 */
  overflow-wrap: anywhere;
}

/* 富文本版正文：换行由 HTML 标签表达，pre-wrap 会把标签间空白也渲染出来 */
rich-text.content-text {
  display: block;
  white-space: normal;
}

/* Seal stamp */
.seal-stamp-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.seal-stamp {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid rgba(182, 69, 47, 0.6);
  padding: 10rpx 20rpx;
  border-radius: 4px;
  transform: rotate(-2deg);
}

.seal-stamp-text {
  font-size: 26rpx;
  color: rgba(182, 69, 47, 0.7);
  letter-spacing: 3px;
}

/* Comments section */
.comments-section {
  border-top: 1px solid rgba(126, 102, 64, 0.1);
  padding-top: 32rpx;
}

.comments-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2723;
}

.comments-count {
  font-size: 28rpx;
}

.comments-empty {
  padding: 40rpx 0;
  text-align: center;
}

.comments-empty-text {
  font-size: 26rpx;
  color: #A8A39B;
}

/* Comment items */
.comment-item {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.comment-avatar {
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 600;
  color: #2A2723;
}

.comment-user.comment-mine {
  color: #4577A4;
}

.comment-time {
  font-size: 22rpx;
  color: #A8A39B;
  flex: 1;
  margin-left: 12rpx;
}

.comment-delete-btn {
  font-size: 22rpx;
  color: #C0856A;
  padding: 0 8rpx;
}

.comment-reply-btn {
  font-size: 22rpx;
  color: #4577A4;
  padding: 0 8rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #4A453E;
  line-height: 1.6;
}

/* Replies */
.replies-wrap {
  margin-top: 14rpx;
  background: #F5EFE2;
  border-radius: 8px;
  padding: 16rpx;
}

.reply-item {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-body {
  flex: 1;
}

.reply-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.reply-user {
  font-size: 24rpx;
  font-weight: 600;
  color: #2A2723;
  display: block;
}

.reply-delete-btn {
  font-size: 20rpx;
  color: #C0856A;
  padding: 0 8rpx;
}

.reply-content {
  font-size: 26rpx;
  color: #4A453E;
  display: block;
  margin: 4rpx 0;
}

.reply-time {
  font-size: 20rpx;
  color: #A8A39B;
  display: block;
}

.bottom-content-pad {
  height: 160rpx;
}

/* Bottom bar */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(251, 247, 238, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(126, 102, 64, 0.1);
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  z-index: 20;
}

.comment-trigger {
  flex: 1;
  background: #F5EFE2;
  border-radius: 24rpx;
  padding: 14rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.comment-trigger-icon {
  width: 30rpx;
  height: 30rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.comment-trigger-text {
  font-size: 26rpx;
  color: #A8A39B;
}

.bar-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  align-items: center;
}

.bar-action {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.bar-action-icon {
  width: 36rpx;
  height: 36rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.bar-action-count {
  font-size: 26rpx;
  color: #A8A39B;
}

.bar-action-count.liked {
  color: #C25A4E;
}

.bar-action-count.faved {
  color: #C9A14A;
}

/* Comment input overlay */
.comment-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
}

.comment-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 39, 35, 0.3);
}

.comment-input-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFCF5;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  border-top: 1px solid rgba(126, 102, 64, 0.1);
}

.comment-real-input {
  flex: 1;
  background: #F5EFE2;
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
  font-size: 28rpx;
  color: #2A2723;
  height: 72rpx;
}

.comment-submit {
  padding: 14rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #A8A39B;
  background: #F5EFE2;
}

.comment-submit.active {
  color: #4577A4;
  background: rgba(69, 119, 164, 0.12);
}

/* Diary images */
.detail-images {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 40rpx 20rpx;
}

.detail-image {
  width: 100%;
  border-radius: 8px;
  background: rgba(126, 102, 64, 0.06);
}

/* v2.1 会员内容墙：30% 预览渐隐 */
.detail-content.is-truncated {
  position: relative;
  overflow: hidden;
}

.content-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 160rpx;
  background: linear-gradient(180deg, rgba(251, 247, 238, 0) 0%, #FBF7EE 92%);
  pointer-events: none;
}

.member-wall {
  text-align: center;
  padding: 8rpx 40rpx 40rpx;
}

.member-wall-text {
  display: block;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  color: #2A2723;
  margin-bottom: 12rpx;
}

.member-wall-hint {
  display: block;
  font-size: 24rpx;
  color: #A8A39B;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.member-wall-btn {
  display: inline-block;
  padding: 18rpx 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #E5C16D, #B89968);
  color: #FFFCF5;
  font-size: 28rpx;
  letter-spacing: 4rpx;
}
