<view class="page-wrap paper-bg" wx:if="{{story}}">
  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="detail-title-wrap">
      <text class="detail-title serif">{{story.title}}</text>
    </view>

    <view class="author-row">
      <view class="avatar-wrap">
        <view class="avatar sm" style="background-color: {{avatarColor}};">
          <text>{{avatarInitial}}</text>
        </view>
        <view wx:if="{{story.authorIsMember}}" class="member-badge">
          <text class="member-badge-text">会</text>
        </view>
      </view>
      <view class="author-meta">
        <text class="author-name">{{story.author}}</text>
        <text class="author-time">{{story.timestamp}}</text>
      </view>
      <view wx:if="{{story.publishStatus === 'draft'}}" class="perm-badge perm-private">
        <view class="perm-ic ic-draft"></view>
      </view>
      <block wx:else>
        <view class="perm-badge perm-member">
          <view class="perm-ic ic-star-gold"></view>
        </view>
        <view wx:if="{{story.isFeatured}}" class="perm-badge perm-public">
          <view class="perm-ic ic-eye"></view>
        </view>
      </block>
    </view>

    <view class="detail-tags" wx:if="{{story.tags && story.tags.length}}">
      <text wx:for="{{story.tags}}" wx:key="*this" class="seal-tag lg">{{item}}</text>
    </view>

    <view class="detail-content">
      <!-- 有样式版（富文本）用 rich-text 渲染；旧纯文本故事回退 text -->
      <rich-text wx:if="{{story.contentRich}}" class="content-text" nodes="{{story.contentRich}}" user-select></rich-text>
      <text wx:else class="content-text" user-select>{{story.content}}</text>
    </view>

    <view wx:if="{{story.images && story.images.length}}" class="detail-images">
      <image
        wx:for="{{story.images}}"
        wx:key="*this"
        class="detail-image"
        src="{{item}}"
        mode="widthFix"
        data-index="{{index}}"
        bindtap="onPreviewImage"
      />
    </view>

    <view class="seal-stamp-wrap">
      <view class="seal-stamp">
        <text class="seal-stamp-text serif">{{story.author}}</text>
      </view>
    </view>

    <view class="comments-section">
      <view class="comments-header">
        <text class="comments-title">评论</text>
        <text class="comments-count ink-3">· {{story.comments}}</text>
      </view>

      <view wx:if="{{comments.length === 0}}" class="comments-empty">
        <text class="comments-empty-text">暂无评论，来说点什么吧</text>
      </view>

      <view wx:for="{{comments}}" wx:key="id" class="comment-item">
        <view class="comment-avatar">
          <view class="avatar sm" style="background-color: {{item.avatarHue !== undefined ? 'hsl(' + item.avatarHue + ',30%,45%)' : '#8B7A4A'}};">
            <text>{{item.user ? item.user[0] : '?'}}</text>
          </view>
        </view>
        <view class="comment-body">
          <view class="comment-header-row">
            <text class="comment-user {{item.isMine ? 'comment-mine' : ''}}">{{item.user}}</text>
            <text class="comment-time">{{item.time}}</text>
            <text class="comment-reply-btn" data-id="{{item.id}}" data-user="{{item.user}}" bindtap="onReplyComment">回复</text>
            <text wx:if="{{item.isMine}}" class="comment-delete-btn" data-id="{{item.id}}" bindtap="onDeleteComment">删除</text>
          </view>
          <text class="comment-content">{{item.content}}</text>
          <view wx:if="{{item.replies && item.replies.length}}" class="replies-wrap">
            <view wx:for="{{item.replies}}" wx:key="id" wx:for-item="reply" class="reply-item">
              <view class="avatar" style="width:40rpx;height:40rpx;font-size:18rpx;background-color:hsl({{reply.avatarHue}},30%,45%);">
                <text>{{reply.user ? reply.user[0] : '?'}}</text>
              </view>
              <view class="reply-body">
                <view class="reply-header-row">
                  <text class="reply-user">{{reply.user}}</text>
                  <text wx:if="{{reply.isMine}}" class="reply-delete-btn" data-id="{{reply.id}}" data-parent="{{item.id}}" bindtap="onDeleteReply">删除</text>
                </view>
                <text class="reply-content">{{reply.content}}</text>
                <text class="reply-time">{{reply.time}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-content-pad"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="comment-trigger" bindtap="onShowCommentInput">
      <view class="comment-trigger-icon ic-pen"></view>
      <text class="comment-trigger-text">写评论…</text>
    </view>
    <view class="bar-actions">
      <view class="bar-action" bindtap="onLike">
        <view class="bar-action-icon {{story.isLiked ? 'ic-heart-on' : 'ic-heart'}}"></view>
        <text class="bar-action-count {{story.isLiked ? 'liked' : ''}}">{{story.likes}}</text>
      </view>
      <view class="bar-action" bindtap="onFav">
        <view class="bar-action-icon {{story.isFavorited ? 'ic-bookmark-on' : 'ic-bookmark'}}"></view>
        <text class="bar-action-count {{story.isFavorited ? 'faved' : ''}}">{{story.favorites}}</text>
      </view>
      <!-- 分享海报仅善选故事提供；非善选只能走右上角原生转发 -->
      <view wx:if="{{story.isFeatured}}" class="bar-action" bindtap="onShare">
        <view class="bar-action-icon ic-share"></view>
      </view>
    </view>
  </view>

  <poster-sheet visible="{{showPosterSheet}}" story="{{story}}" bind:close="onPosterClose"></poster-sheet>

  <view wx:if="{{showCommentInput}}" class="comment-overlay">
    <view class="comment-overlay-mask" bindtap="onHideCommentInput"></view>
    <view class="comment-input-bar">
      <view class="avatar sm" style="background-color: {{userAvatarColor}}; flex-shrink: 0;">
        <text>{{userAvatarInitial}}</text>
      </view>
      <input class="comment-real-input" placeholder="{{replyTo ? '回复 ' + replyTo.user : '说点什么…'}}" placeholder-style="color:#A8A39B;"
        value="{{commentInput}}" bindinput="onCommentInput" focus="{{showCommentInput}}"
        confirm-type="send" bindconfirm="onSubmitComment"/>
      <view class="comment-submit {{commentInput ? 'active' : ''}}" bindtap="onSubmitComment">发送</view>
    </view>
  </view>
</view>

<!-- 微信登录弹窗：互动被拦或会员专享故事（-2）时在本页拉起（story 为空时也需可见，故置于根节点之外） -->
<login-sheet
  visible="{{showLoginSheet}}"
  subtitle="你刚刚被打动了，对吗？登录后为喜欢的文字点赞、收藏，也开始记录属于你自己的故事。"
  bind:close="onLoginClose"
  bind:success="onLoginSuccess"
></login-sheet>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
