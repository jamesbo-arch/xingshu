<view class="page-wrap paper-bg">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- skip -->
  <view class="skip-row">
    <text class="skip-btn" bindtap="onSkip">跳过</text>
  </view>

  <!-- branding（v2.1 文案：从"解锁功能"重构为"加入仪式"） -->
  <view class="brand-wrap">
    <view class="brand-seal serif">醒</view>
    <text class="brand-name serif">成为醒书的一员</text>
    <text class="brand-sub">{{fromInteraction ? '你刚刚被打动了，对吗？留下你的身份，为喜欢的文字点赞、收藏，也开始记录属于你自己的故事。' : '留下你的身份，加入一群认真生活的人。'}}</text>
  </view>

  <!-- phone auth card -->
  <view class="auth-card">
    <text class="auth-card-title">手机号验证</text>
    <text class="auth-card-desc">我们承诺：你的信息仅用于身份识别，绝不外泄</text>

    <block wx:if="{{!phone}}">
      <view class="manual-input-row">
        <input
          class="manual-input"
          type="number"
          placeholder="请输入手机号"
          placeholder-style="color:#C8C2B6;"
          maxlength="11"
          value="{{manualPhone}}"
          bindinput="onManualPhoneInput"
        />
        <view class="manual-confirm-btn" bindtap="onConfirmManualPhone">确认</view>
      </view>
    </block>

    <view wx:else class="phone-done-row">
      <text class="phone-done-icon">✓</text>
      <text class="phone-done-num">{{phoneMasked}}</text>
      <text class="phone-reauth" bindtap="onReauth">重新授权</text>
    </view>
  </view>

  <!-- agreement -->
  <view class="agreement-row" bindtap="onToggleAgreement">
    <view class="agreement-circle {{agreed ? 'checked' : ''}}">
      <text wx:if="{{agreed}}" class="agreement-tick">✓</text>
    </view>
    <text class="agreement-text">已阅读并同意</text>
    <text class="agreement-link">《服务协议》</text>
    <text class="agreement-sep"> </text>
    <text class="agreement-link">《隐私协议》</text>
  </view>

  <!-- save -->
  <view class="btn-save {{phone && agreed ? '' : 'disabled'}}" bindtap="onSave">
    <text>加入醒书</text>
  </view>
</view>
