page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

/* ic-back 是背景图类，必须显式给宽高，否则 0×0 不可见 */
.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -12rpx;
}

.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

.qa-list {
  flex: 1;
  overflow: hidden;
  padding: 0 24rpx;
}

/* 非 tab 页无需为 tab-bar 让位 */
.list-bottom-pad {
  height: calc(env(safe-area-inset-bottom) + 140rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #D6D0C2;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.empty-text {
  font-size: 28rpx;
  color: #A8A39B;
}

.empty-hint {
  font-size: 24rpx;
  color: #C4BFB6;
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  background: #2A2723;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(42, 39, 35, 0.32);
  z-index: 30;
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

qa-card {
  display: block;
  margin-bottom: 24rpx;
}

qa-card:first-child {
  margin-top: 8rpx;
}
