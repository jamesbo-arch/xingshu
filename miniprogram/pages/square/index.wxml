<view class="page-wrap paper-bg">
  <!-- Status bar spacer -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Custom header -->
  <view class="page-header">
    <view class="header-top">
      <view style="display:flex;flex-direction:row;align-items:center;gap:14rpx;"><text class="page-title serif">醒書日記</text><kefu-fab /></view>
    </view>

    <!-- Search bar -->
    <view class="search-row">
      <view class="search-bar">
        <view class="search-icon ic-search"></view>
        <input
          class="search-input"
          placeholder="搜索标题 / 内容 / 作者"
          placeholder-style="color: #A8A39B; font-size: 28rpx;"
          value="{{search}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
        <view wx:if="{{search}}" class="search-clear ic-close" bindtap="onSearchClear"></view>
      </view>
      <view class="filter-btn {{filtersActive ? 'filter-active' : ''}}" bindtap="onOpenFilter">
        <view class="filter-icon {{filtersActive ? 'ic-filter-w' : 'ic-filter'}}"></view>
        <view wx:if="{{filtersActive}}" class="filter-dot"></view>
      </view>
    </view>
  </view>

  <!-- Diary list -->
  <scroll-view class="diary-list" scroll-y enhanced show-scrollbar="{{false}}"
    bindscrolltolower="onReachBottom" lower-threshold="150"
    refresher-enabled refresher-background="#FBF7EE" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view wx:if="{{diaries.length === 0}}" class="empty-state">
      <text class="empty-icon">○</text>
      <text class="empty-text">暂无日记</text>
    </view>
    <diary-card
      wx:for="{{diaries}}"
      wx:key="id"
      diary="{{item}}"
      show-actions="{{false}}"
      bind:open="onCardOpen"
      bind:like="onCardLike"
      bind:fav="onCardFav"
      bind:share="onCardShare"
    ></diary-card>
    <view class="list-bottom-pad {{actBannerCount ? 'pad-banner' : ''}}"></view>
  </scroll-view>

  <!-- 近期活动轮播（共享组件）：固定在 tab-bar 之上，可手动关闭（当次会话）；无未开始活动时容器隐藏 -->
  <view class="act-banner-bar" hidden="{{!actBannerCount}}">
    <act-banner id="actBanner" bind:change="onActBannerChange"></act-banner>
  </view>

  <!-- FAB -->
  <view class="fab {{actBannerCount ? 'fab-raised' : ''}}" bindtap="onFabTap">
    <view class="fab-icon ic-pen-w"></view>
  </view>

  <!-- Filter sheet -->
  <filter-sheet
    visible="{{showFilterSheet}}"
    filters="{{filters}}"
    all-tags="{{allTags}}"
    bind:close="onCloseFilter"
    bind:apply="onApplyFilter"
  ></filter-sheet>

  <!-- Poster sheet -->
  <poster-sheet
    visible="{{showPosterSheet}}"
    diary="{{posterDiary}}"
    bind:close="onClosePoster"
    bind:shared="onShared"
  ></poster-sheet>

  <!-- Member guard -->
  <member-guard
    visible="{{showMemberGuard}}"
    identity="{{userIdentity}}"
    bind:close="onCloseMemberGuard"
    bind:authorize="onGuardAuthorize"
    bind:joinMember="onGuardJoinMember"
  ></member-guard>

  <!-- v2.3 微信登录弹窗 -->
  <login-sheet
    visible="{{showLoginSheet}}"
    subtitle="你刚刚被打动了，对吗？登录后为喜欢的文字点赞、收藏，也开始记录属于你自己的故事。"
    bind:close="onLoginClose"
    bind:success="onLoginSuccess"
  ></login-sheet>
</view>

<!-- 隐私授权弹窗（敏感接口首次调用时触发） -->
<privacy-popup></privacy-popup>
