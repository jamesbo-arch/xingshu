/* 禁用页面级滚动/回弹：仅内部 scroll-view 滚动，锁定顶部标题栏 */
page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Header */
.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

/* Search bar */
.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
  gap: 10rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2A2723;
  height: 40rpx;
}

.search-clear {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.filter-active {
  background: #2A2723;
}

.filter-icon {
  width: 36rpx;
  height: 36rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: #B6452F;
  border-radius: 50%;
  border: 2px solid #FBF7EE;
}

/* List */
.diary-list {
  flex: 1;
  min-height: 0;
  width: 100%;
  padding: 0 24rpx;
}

.list-bottom-pad {
  height: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* 活动轮播可见时，列表底部额外让出轮播高度，末条卡片不被遮挡 */
.list-bottom-pad.pad-banner {
  height: calc(100rpx + env(safe-area-inset-bottom) + 180rpx);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #D6D0C2;
}

.empty-text {
  font-size: 28rpx;
  color: #A8A39B;
}

/* FAB */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  transition: bottom 0.25s ease;
  width: 108rpx;
  height: 108rpx;
  background: #2A2723;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(42, 39, 35, 0.32);
  z-index: 30;
}

/* 活动轮播可见时 FAB 上移让位 */
.fab.fab-raised {
  bottom: calc(120rpx + env(safe-area-inset-bottom) + 156rpx);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* 近期活动轮播：满宽贴底，固定在自定义 tab-bar（100rpx+安全区）正上方，深红底与纸色页面差异化 */
.act-banner-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.act-banner-swiper {
  height: 160rpx;
}

/* 指示点下移到底缘，避免与第二行文字重叠 */
.act-banner-swiper .wx-swiper-dots.wx-swiper-dots-horizontal {
  bottom: 8rpx;
}

.act-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  height: 100%;
  box-sizing: border-box;
  padding: 0 32rpx 10rpx;
  background: linear-gradient(135deg, #A73D28, #C2563F);
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -6rpx 24rpx rgba(42, 39, 35, 0.10);
}

.act-banner-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #FFF7EC;
  border: 2rpx solid rgba(255, 247, 236, 0.75);
  border-radius: 6rpx;
  padding: 6rpx 10rpx;
}

.act-banner-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.act-banner-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.act-banner-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFDFA8;
}

.act-banner-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1;
}
