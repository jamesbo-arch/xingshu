/* 禁用页面级滚动/回弹：仅内部 scroll-view 滚动，锁定顶部标题栏 */
page { height: 100%; overflow: hidden; }

.page-wrap {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Header */
.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

/* Search bar */
.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
  gap: 10rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2A2723;
  height: 40rpx;
}

.search-clear {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FFFCF5;
  border: 0.5px solid rgba(126, 102, 64, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.filter-active {
  background: #2A2723;
}

.filter-icon {
  width: 36rpx;
  height: 36rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.filter-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: #B6452F;
  border-radius: 50%;
  border: 2px solid #FBF7EE;
}

/* List */
.diary-list {
  flex: 1;
  min-height: 0;
  width: 100%;
  padding: 0 24rpx;
}

.list-bottom-pad {
  height: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #D6D0C2;
}

.empty-text {
  font-size: 28rpx;
  color: #A8A39B;
}

/* FAB */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  background: #2A2723;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(42, 39, 35, 0.32);
  z-index: 30;
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* 近期活动横幅 */
.act-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin: 4rpx 0 20rpx;
  padding: 20rpx 24rpx;
  background: #FFFCF5;
  border: 1px solid rgba(126, 102, 64, 0.16);
  border-radius: 20rpx;
}

.act-banner-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #B6452F;
  border: 2rpx solid #B6452F;
  border-radius: 6rpx;
  padding: 6rpx 10rpx;
  opacity: 0.85;
}

.act-banner-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.act-banner-title {
  font-size: 28rpx;
  color: #2A2723;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.act-banner-time {
  font-size: 22rpx;
  color: #A8A39B;
}

.act-banner-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #D6D0C2;
  line-height: 1;
}
