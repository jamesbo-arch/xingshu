.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Header */
.page-header {
  padding: 16rpx 32rpx 20rpx;
  background: #FBF7EE;
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A2723;
  letter-spacing: 2px;
}

/* Search bar */
.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F5EFE2;
  border-radius: 24rpx;
  padding: 14rpx 20rpx;
  gap: 10rpx;
}

.search-icon {
  font-size: 30rpx;
  color: #A8A39B;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2A2723;
  height: 40rpx;
}

.search-clear {
  font-size: 26rpx;
  color: #A8A39B;
  padding: 4rpx 6rpx;
}

.filter-btn {
  width: 72rpx;
  height: 72rpx;
  background: #F5EFE2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.filter-active {
  background: #2A2723;
}

.filter-active .filter-icon {
  color: #FBF7EE;
}

.filter-icon {
  font-size: 32rpx;
  color: #4A453E;
}

.filter-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: #B6452F;
  border-radius: 50%;
  border: 2px solid #FBF7EE;
}

/* List */
.diary-list {
  flex: 1;
  width: 100%;
  padding: 0 24rpx;
  height: calc(100vh - 280rpx);
}

.list-bottom-pad {
  height: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #D6D0C2;
}

.empty-text {
  font-size: 28rpx;
  color: #A8A39B;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  background: #2A2723;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(42, 39, 35, 0.25);
  z-index: 30;
}

.fab-icon {
  font-size: 40rpx;
  color: #FBF7EE;
}
